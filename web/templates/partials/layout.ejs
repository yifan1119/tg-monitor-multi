<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · tg-monitor-multi</title>
  <link rel="stylesheet" href="/css/neon.css">
</head>
<body>
  <div class="app">
    <% if (typeof showNav === 'undefined' || showNav) { %>
      <header class="topbar">
        <a href="/dashboard" style="text-decoration:none;">
          <div class="brand">
            TG-MONITOR-MULTI
            <span class="version">v<%= version %></span>
          </div>
        </a>
        <nav class="nav">
          <a href="/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">总览</a>
          <a href="/depts"     class="<%= active === 'depts' ? 'active' : '' %>">部门</a>
          <a href="/review"    class="<%= active === 'review' ? 'active' : '' %>">审查报告</a>
          <a href="/ops"       class="<%= active === 'ops' ? 'active' : '' %>">运维</a>
          <a href="/settings"  class="<%= active === 'settings' ? 'active' : '' %>">设置</a>
          <a href="/logout" style="color:var(--text-dim);">登出</a>
        </nav>
      </header>
    <% } %>

    <main class="main">
      <%- body %>
    </main>

    <footer class="footer">
      TG-MONITOR-MULTI · v<%= version %> · <%= mode === 'mock' ? 'MOCK 预览模式' : 'LIVE' %>
      &nbsp;·&nbsp;
      <a href="https://github.com/yifan1119/tg-monitor-multi" style="color:var(--text-dim);">GitHub</a>
    </footer>
  </div>
  <%- script %>
</body>
</html>
