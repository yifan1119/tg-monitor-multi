<% const fd = locals.formData || {}; %>
<% const cfg = locals.config || {}; %>
<div class="page-header">
  <div>
    <div class="page-title">编辑部门 · <%= dept.name %></div>
    <div class="page-subtitle">修改 <code>depts/<%= dept.name %>/config.json</code></div>
  </div>
  <div>
    <a href="/depts" class="btn ghost">返回列表</a>
  </div>
</div>

<% if (locals.flash) { %>
  <div class="panel" style="border-left: 3px solid var(--green); background: rgba(0, 255, 149, 0.06);">
    <div style="color: var(--green); font-weight: 700; font-size: 0.85rem;">✓ <%= flash %></div>
  </div>
<% } %>
<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem; margin-bottom: 0.4rem;">⚠ 保存失败</div>
    <div style="color: var(--text-0); font-size: 0.9rem;"><%= error %></div>
  </div>
<% } %>

<!-- ─── 进程状态卡 ─────────────────────────────── -->
<div class="panel">
  <div class="panel-title">PM2 进程状态</div>
  <div style="overflow-x: auto;">
    <table>
      <thead>
        <tr><th>类型</th><th>名称</th><th>状态</th><th>CPU</th><th>RAM</th><th>重启</th><th>Uptime</th></tr>
      </thead>
      <tbody>
        <% ["worker"].forEach(k => {
          const p = procs.find(x => x.kind === k);
        %>
          <tr>
            <td>worker</td>
            <td><code>tg-<%= k %>-<%= dept.name %></code></td>
            <% if (p) { %>
              <td class="status-<%= p.status %>">● <%= p.status %></td>
              <td><%= p.cpu.toFixed(1) %>%</td>
              <td><%= p.mem %> MB</td>
              <td><%= p.restarts %></td>
              <td><%= p.uptime %></td>
            <% } else { %>
              <td style="color: var(--text-dim);">— 未启动</td>
              <td>—</td><td>—</td><td>—</td><td>—</td>
            <% } %>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div style="display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap;">
    <form action="/depts/<%= dept.name %>/restart" method="POST" style="display: inline;">
      <button type="submit" class="btn ghost" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">↻ 重启</button>
    </form>
    <form action="/depts/<%= dept.name %>/start" method="POST" style="display: inline;">
      <button type="submit" class="btn ghost" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">▶ 启动</button>
    </form>
    <form action="/depts/<%= dept.name %>/stop" method="POST" style="display: inline;">
      <button type="submit" class="btn ghost" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">⏸ 停止</button>
    </form>
    <div style="flex: 1;"></div>
    <form action="/depts/<%= dept.name %>/delete" method="POST" style="display: inline;"
      onsubmit="return confirm('确认删除部门 <%= dept.name %>？目录会搬到 .trash-<时间戳>-<%= dept.name %> 但不会立刻清除. session.txt 会一并搬走, 请自行备份.');">
      <button type="submit" class="btn danger" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">🗑 删除部门</button>
    </form>
  </div>
</div>

<!-- ─── Session 状态 ─────────────────────────────── -->
<div class="panel">
  <div class="panel-title">Telegram 登入状态</div>
  <% if (dept.sessionOk) { %>
    <div style="padding: 0.75rem 1rem; background: rgba(0, 255, 149, 0.06); border-left: 3px solid var(--green); border-radius: 0 6px 6px 0; font-size: 0.85rem;">
      <span style="color: var(--green); font-weight: 700;">✓ 已登入</span>
      <span style="color: var(--text-dim); margin-left: 0.75rem;">session.txt 已存在</span>
      <div style="margin-top: 0.5rem;">
        <a href="/depts/<%= dept.name %>/login" class="btn ghost" style="padding: 0.35rem 0.8rem; font-size: 0.75rem;">重新登入</a>
      </div>
    </div>
  <% } else { %>
    <div style="padding: 0.75rem 1rem; background: rgba(255, 201, 64, 0.08); border-left: 3px solid var(--yellow); border-radius: 0 6px 6px 0; font-size: 0.85rem;">
      <span style="color: var(--yellow); font-weight: 700;">⚠ 尚未登入</span>
      <div style="color: var(--text-1); margin-top: 0.4rem;">进程会因为缺 session.txt 而报错. 请先完成 TG 登入.</div>
      <div style="margin-top: 0.5rem;">
        <a href="/depts/<%= dept.name %>/login" class="btn">🔑 去登入 TG</a>
      </div>
    </div>
  <% } %>
</div>

<!-- ─── 配置表单 ─────────────────────────────── -->
<form action="/depts/<%= dept.name %>/edit" method="POST">
  <div class="panel">
    <div class="panel-title">基本资讯</div>
    <div class="form-group">
      <label>显示名称 (display)</label>
      <input type="text" name="display" value="<%= fd.display != null ? fd.display : (cfg.display || '') %>" required>
    </div>
    <div class="form-group" style="position: relative;">
      <label>中转群名称 (outputChatName / inputChatName)</label>
      <input type="text" id="fld-outputChatName" name="outputChatName" value="<%= fd.outputChatName != null ? fd.outputChatName : (cfg.outputChatName || '') %>" required autocomplete="off">
      <div class="hint">
        命中关键字时会把提醒消息推到这个群.
        <% if (dept.sessionOk) { %>
          <button type="button" class="btn ghost" style="padding:0.15rem 0.5rem;font-size:0.7rem;margin-left:0.5rem;" onclick="openGroupPicker()">🔍 从该号加入的群选</button>
          <span id="tg-groups-meta" style="font-size:0.72rem;color:var(--text-dim);margin-left:0.4rem;"></span>
        <% } else { %>
          <span style="color:var(--text-dim);font-size:0.72rem;">(登入 TG 后可用下拉选群)</span>
        <% } %>
      </div>

      <!-- 群选择下拉面板 (嵌入式, 不浮空) -->
      <div id="group-picker" style="display:none; margin-top:0.6rem; background:rgba(7,10,21,0.7); border:1px solid var(--accent); border-radius:6px; max-height:360px; overflow:hidden;">
        <div style="padding:0.6rem; border-bottom:1px solid var(--panel-border);">
          <input type="text" id="group-picker-search" placeholder="🔍 搜索群名 (中文/英文)..." style="width:100%;padding:0.4rem 0.6rem;background:rgba(7,10,21,0.5);border:1px solid var(--panel-border);border-radius:4px;color:var(--text-0);font-size:0.85rem;" oninput="filterGroupList()">
        </div>
        <div id="group-picker-list" style="max-height:320px; overflow-y:auto; padding:0.3rem 0;"></div>
        <div style="padding:0.3rem 0.6rem; border-top:1px solid var(--panel-border); font-size:0.7rem; color:var(--text-dim); display:flex; justify-content:space-between;">
          <span id="group-picker-count">—</span>
          <button type="button" onclick="closeGroupPicker()" style="background:none;border:none;color:var(--text-dim);font-size:0.7rem;cursor:pointer;">关闭 (Esc)</button>
        </div>
      </div>

      <script>
        let allGroups = [];
        async function openGroupPicker() {
          const picker = document.getElementById("group-picker");
          const meta = document.getElementById("tg-groups-meta");
          const listEl = document.getElementById("group-picker-list");
          picker.style.display = "block";
          listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">拉取中...</div>';
          meta.textContent = '';
          try {
            const r = await fetch("/api/tg-dialogs/dept/<%= dept.name %>").then(r => r.json());
            if (!r.ok) {
              listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">✗ ' + r.error + '</div>';
              return;
            }
            allGroups = r.dialogs;
            renderGroupList(allGroups);
            meta.innerHTML = '<span style="color:var(--green);">✓ ' + r.dialogs.length + ' 个群' + (r.cached ? ' (缓存)' : '') + '</span>';
            document.getElementById("group-picker-search").focus();
          } catch (e) {
            listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">请求失败: ' + e.message + '</div>';
          }
        }
        function renderGroupList(list) {
          const listEl = document.getElementById("group-picker-list");
          const count = document.getElementById("group-picker-count");
          if (list.length === 0) {
            listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">没匹配的群</div>';
            count.textContent = '0 / ' + allGroups.length;
            return;
          }
          listEl.innerHTML = list.map(d => {
            const escaped = String(d.title).replace(/"/g, '&quot;').replace(/</g, '&lt;');
            return '<div onclick="pickGroup(\'' + encodeURIComponent(d.title) + '\')" style="padding:0.45rem 0.8rem;cursor:pointer;font-size:0.85rem;color:var(--text-0);display:flex;justify-content:space-between;align-items:center;" onmouseover="this.style.background=\'rgba(0,230,255,0.08)\'" onmouseout="this.style.background=\'\'">' +
              '<span>' + escaped + '</span>' +
              '<span style="color:var(--text-dim);font-size:0.7rem;">' + d.type + (d.unread ? ' · 未读 ' + d.unread : '') + '</span>' +
            '</div>';
          }).join('');
          count.textContent = list.length + ' / ' + allGroups.length;
        }
        function filterGroupList() {
          const q = document.getElementById("group-picker-search").value.toLowerCase().trim();
          if (!q) return renderGroupList(allGroups);
          renderGroupList(allGroups.filter(d => d.title.toLowerCase().includes(q)));
        }
        function pickGroup(encodedTitle) {
          const title = decodeURIComponent(encodedTitle);
          document.getElementById("fld-outputChatName").value = title;
          closeGroupPicker();
        }
        function closeGroupPicker() {
          document.getElementById("group-picker").style.display = "none";
          document.getElementById("group-picker-search").value = "";
        }
        document.addEventListener("keydown", e => {
          if (e.key === "Escape") closeGroupPicker();
        });
        document.addEventListener("click", e => {
          const picker = document.getElementById("group-picker");
          if (picker && picker.style.display !== "none" &&
              !picker.contains(e.target) &&
              !e.target.closest('button[onclick="openGroupPicker()"]')) {
            closeGroupPicker();
          }
        });
      </script>
    </div>
  </div>

  <div class="panel">
    <div class="panel-title">关键字命中 Sheet (主表)</div>
    <div class="form-group">
      <label>Spreadsheet ID</label>
      <input type="text" id="fld-spreadsheetId" name="spreadsheetId" value="<%= fd.spreadsheetId != null ? fd.spreadsheetId : (cfg.spreadsheetId || '') %>" required>
    </div>
    <div class="form-group" style="position: relative;">
      <label>工作表分页名称 (sheetName)</label>
      <input type="text" id="fld-sheetName" name="sheetName" value="<%= fd.sheetName != null ? fd.sheetName : (cfg.sheetName || '') %>" required autocomplete="off">
      <div class="hint">
        <button type="button" class="btn ghost" style="padding:0.15rem 0.5rem;font-size:0.7rem;" onclick="openTabPicker()">🔍 从该 Sheet 载入分页列表</button>
        <span id="tab-picker-meta" style="font-size:0.72rem;color:var(--text-dim);margin-left:0.4rem;"></span>
      </div>
      <div id="tab-picker" style="display:none; margin-top:0.5rem; background:rgba(7,10,21,0.7); border:1px solid var(--accent); border-radius:6px; max-height:240px; overflow:hidden;">
        <div id="tab-picker-list" style="max-height:260px; overflow-y:auto; padding:0.3rem 0;"></div>
        <div style="padding:0.3rem 0.6rem; border-top:1px solid var(--panel-border); font-size:0.7rem; color:var(--text-dim); text-align:right;">
          <button type="button" onclick="closeTabPicker()" style="background:none;border:none;color:var(--text-dim);font-size:0.7rem;cursor:pointer;">关闭 (Esc)</button>
        </div>
      </div>
    </div>
    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
      <button type="button" class="btn ghost" style="padding:0.4rem 0.9rem;font-size:0.75rem;" onclick="testSheetWrite()">🧪 测试写入</button>
      <span id="sheet-test-result" style="font-size:0.78rem;color:var(--text-dim);"></span>
    </div>

    <!-- 群名变更分页 (可选, 同一张 Sheet 的另一个 tab) -->
    <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px dashed var(--panel-border);">
      <div style="font-size: 0.82rem; color: var(--text-1); margin-bottom: 0.6rem;">
        📌 <strong>群名变更分页</strong> (可选, 同这张 Sheet 的另一个 tab)
      </div>
      <div class="form-group" style="margin-bottom:0.4rem;">
        <label style="font-size:0.8rem;">分页名称</label>
        <input type="text" id="fld-titleSheetName" name="titleSheetName" value="<%= fd.titleSheetName != null ? fd.titleSheetName : ((cfg.titleSheet && cfg.titleSheet.sheetName) || '') %>" placeholder="例: 群名变更  (留空 = 群名变更只推中转群, 不写表)" autocomplete="off">
        <div class="hint">
          群改名时 worker 会在这个分页写一行 (原群名 / 新群名 / 变更时间 / 操作人).
          Spreadsheet ID 用上面同一张 <code>fld-spreadsheetId</code>.
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
        <button type="button" class="btn ghost" style="padding:0.3rem 0.7rem;font-size:0.72rem;color:var(--accent);border-color:var(--accent);" onclick="initTitleSheet()">⚡ 初始化群名变更模板</button>
        <span id="title-sheet-result" style="font-size:0.75rem;color:var(--text-dim);"></span>
      </div>
      <script>
        async function initTitleSheet() {
          const out = document.getElementById("title-sheet-result");
          const spreadsheetId = document.getElementById("fld-spreadsheetId").value.trim();
          const sheetName = document.getElementById("fld-titleSheetName").value.trim();
          if (!spreadsheetId) { out.innerHTML = '<span style="color:var(--red);">先填上面 Spreadsheet ID</span>'; return; }
          if (!sheetName) { out.innerHTML = '<span style="color:var(--red);">先填群名变更分页名称</span>'; return; }
          if (!confirm('⚡ 初始化群名变更模板 "' + sheetName + '"?')) return;
          out.innerHTML = '初始化中...';
          try {
            const r = await fetch("/api/sheet-template/init", {
              method: "POST", headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ spreadsheetId, sheetName, type: "title", dept: "<%= dept.name %>" }),
            }).then(r => r.json());
            if (r.ok) out.innerHTML = '<span style="color:var(--green);">✓ ' + (r.created ? '已建分页' : '已重设模板') + '</span>';
            else out.innerHTML = '<span style="color:var(--red);">✗ ' + r.error + '</span>';
          } catch (e) { out.innerHTML = '<span style="color:var(--red);">请求失败: ' + e.message + '</span>'; }
        }
      </script>
    </div>
    <script>
      async function initSheetTemplate() {
        const out = document.getElementById("sheet-test-result");
        const spreadsheetId = document.getElementById("fld-spreadsheetId").value.trim();
        const sheetName = document.getElementById("fld-sheetName").value.trim();
        if (!spreadsheetId || !sheetName) { out.innerHTML = '<span style="color:var(--red);">先填 Spreadsheet ID + 分页</span>'; return; }
        if (!confirm('⚡ 初始化模板 "' + sheetName + '"?\n- 如果分页不存在 → 建立\n- 如果存在 → 重设表头 + 斑马纹 (不清已有数据)')) return;
        out.innerHTML = '初始化中...';
        try {
          const r = await fetch("/api/sheet-template/init", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ spreadsheetId, sheetName, type: "keyword", dept: "<%= dept.name %>" }),
          }).then(r => r.json());
          if (r.ok) {
            out.innerHTML = '<span style="color:var(--green);">✓ ' + (r.created ? '已建分页' : '已重设模板') + ' (' + r.headers.length + ' 列) · ' + r.spreadsheetTitle + '</span>';
          } else {
            out.innerHTML = '<span style="color:var(--red);">✗ ' + r.error + '</span>';
          }
        } catch (e) { out.innerHTML = '<span style="color:var(--red);">请求失败: ' + e.message + '</span>'; }
      }
    </script>
    <script>
      async function openTabPicker() {
        const spreadsheetId = document.getElementById("fld-spreadsheetId").value.trim();
        const meta = document.getElementById("tab-picker-meta");
        const picker = document.getElementById("tab-picker");
        const listEl = document.getElementById("tab-picker-list");
        if (!spreadsheetId) { meta.innerHTML = '<span style="color:var(--red);">请先填 Spreadsheet ID</span>'; return; }
        picker.style.display = "block";
        listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">载入中...</div>';
        meta.textContent = '';
        try {
          const r = await fetch("/api/sheet-tabs?spreadsheetId=" + encodeURIComponent(spreadsheetId)).then(r => r.json());
          if (!r.ok) { listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">✗ ' + r.error + '</div>'; return; }
          if (r.tabs.length === 0) { listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);">此 Sheet 没有分页</div>'; return; }
          listEl.innerHTML = r.tabs.map(t => {
            const esc = String(t.title).replace(/"/g, '&quot;').replace(/</g, '&lt;');
            return '<div onclick="pickTab(\'' + encodeURIComponent(t.title) + '\')" style="padding:0.45rem 0.8rem;cursor:pointer;font-size:0.85rem;color:var(--text-0);" onmouseover="this.style.background=\'rgba(0,230,255,0.08)\'" onmouseout="this.style.background=\'\'">' + esc + '</div>';
          }).join('');
          meta.innerHTML = '<span style="color:var(--green);">✓ ' + r.tabs.length + ' 个分页 (Sheet: ' + (r.spreadsheetTitle||'') + ')</span>';
        } catch (e) { listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">请求失败: ' + e.message + '</div>'; }
      }
      function pickTab(encoded) { document.getElementById("fld-sheetName").value = decodeURIComponent(encoded); closeTabPicker(); }
      function closeTabPicker() { document.getElementById("tab-picker").style.display = "none"; }
      document.addEventListener("keydown", e => { if (e.key === "Escape") closeTabPicker(); });
      document.addEventListener("click", e => {
        const p = document.getElementById("tab-picker");
        if (p && p.style.display !== "none" && !p.contains(e.target) && !e.target.closest('button[onclick="openTabPicker()"]')) closeTabPicker();
      });
    </script>
    <script>
      async function testSheetWrite() {
        const out = document.getElementById("sheet-test-result");
        const spreadsheetId = document.getElementById("fld-spreadsheetId").value.trim();
        const sheetName = document.getElementById("fld-sheetName").value.trim();
        if (!spreadsheetId || !sheetName) { out.innerHTML = '<span style="color:var(--red);">请先填 Spreadsheet ID + 分页名称</span>'; return; }
        out.innerHTML = '测试中...';
        try {
          const r = await fetch("/api/test/sheet", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ spreadsheetId, sheetName }),
          }).then(r => r.json());
          if (r.ok) {
            let html = `<span style="color:var(--green);">✓ 写入成功</span> <span style="color:var(--text-dim);">(Sheet: "${r.sheetTitle}" · 已自动清理测试行)</span>`;
            if (r.cleanupWarning) html += `<br><span style="color:var(--yellow);">⚠ ${r.cleanupWarning}</span>`;
            out.innerHTML = html;
          } else {
            let html = `<span style="color:var(--red);">✗ ${r.error}</span>`;
            if (r.availableTabs) html += `<br><span style="color:var(--text-dim);">可用分页: ${r.availableTabs.join(", ")}</span>`;
            out.innerHTML = html;
          }
        } catch (e) { out.innerHTML = '<span style="color:var(--red);">测试请求失败: ' + e.message + '</span>'; }
      }
    </script>
  </div>

  <div class="panel">
    <div class="panel-title">关键字</div>
    <div class="form-group">
      <label>关键字列表</label>
      <input type="hidden" id="fld-keywords" name="keywords" value="<%= fd.keywords != null ? fd.keywords : (cfg.keywords || []).join(', ') %>">
      <div id="kw-tags" style="display:flex;flex-wrap:wrap;gap:0.4rem;padding:0.5rem;min-height:48px;background:rgba(7,10,21,0.4);border:1px solid var(--panel-border);border-radius:6px;"></div>
      <div style="display:flex;gap:0.5rem;margin-top:0.5rem;align-items:center;">
        <input type="text" id="kw-input" placeholder="输关键字 + Enter 添加 (或逗号)" style="flex:1;padding:0.4rem 0.6rem;font-family:'JetBrains Mono',monospace;" onkeydown="kwKeyDown(event)">
        <button type="button" class="btn ghost" style="padding:0.4rem 0.9rem;font-size:0.75rem;" onclick="kwAdd()">+ 添加</button>
      </div>
      <div class="hint" style="margin-top:0.5rem;">
        <span style="color:var(--text-dim);">常用 (点击添加):</span>
        <% const presets = ["到期","续费","下架","上架","暂停","地址","打款","欠费","对账","不跑了","费用","余额","退款"]; %>
        <% presets.forEach(p => { %>
          <button type="button" onclick="kwAddPreset('<%= p %>')" style="padding:0.1rem 0.5rem;margin:0.15rem 0.1rem;background:rgba(0,230,255,0.06);border:1px solid rgba(0,230,255,0.2);border-radius:10px;color:var(--accent);font-size:0.72rem;cursor:pointer;"><%= p %></button>
        <% }); %>
      </div>
    </div>
    <div class="form-group">
      <label style="font-size: 0.8rem; color: var(--text-dim);">🧪 测试文本 (看命中哪些关键字, 不保存):</label>
      <textarea id="fld-preview-text" rows="3" style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;"
        placeholder="贴一段真实消息进来, 看会不会命中" oninput="previewMatch()">XX客户到期提醒, 请确认是否续费. 另外某个账号欠费3天了.</textarea>
    </div>
    <div id="preview-out" style="padding: 0.75rem 1rem; background: rgba(7, 10, 21, 0.5); border-radius: 6px; font-size: 0.85rem; line-height: 1.8; color: var(--text-dim); min-height: 60px;">
      <span style="color: var(--text-dim);">改关键字或测试文本, 这里会实时显示命中结果</span>
    </div>
    <script>
      // ─── 关键字标签管理 ───
      let kwList = [];
      function kwLoad() {
        const raw = document.getElementById("fld-keywords").value || "";
        kwList = raw.split(/[,，、\n\r]+/).map(s => s.trim()).filter(Boolean);
        kwRender();
      }
      function kwRender() {
        const box = document.getElementById("kw-tags");
        if (kwList.length === 0) {
          box.innerHTML = '<span style="color:var(--text-dim);font-size:0.8rem;align-self:center;">(还没有关键字, 输入或点击常用添加)</span>';
        } else {
          box.innerHTML = kwList.map((k, i) => {
            const esc = String(k).replace(/"/g, '&quot;').replace(/</g, '&lt;');
            return '<span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.2rem 0.5rem 0.2rem 0.7rem;background:rgba(0,230,255,0.1);border:1px solid rgba(0,230,255,0.3);border-radius:14px;color:var(--accent);font-size:0.8rem;font-family:\'JetBrains Mono\',monospace;">' +
              '<span>' + esc + '</span>' +
              '<button type="button" onclick="kwRemove(' + i + ')" style="background:none;border:none;color:var(--red);font-size:1rem;cursor:pointer;padding:0;line-height:1;">×</button>' +
              '</span>';
          }).join('');
        }
        document.getElementById("fld-keywords").value = kwList.join(", ");
        previewMatch();
      }
      function kwAdd() {
        const input = document.getElementById("kw-input");
        const val = input.value.trim();
        if (!val) return;
        val.split(/[,，、]+/).map(s => s.trim()).filter(Boolean).forEach(k => {
          if (!kwList.includes(k)) kwList.push(k);
        });
        input.value = "";
        kwRender();
      }
      function kwAddPreset(k) { if (!kwList.includes(k)) { kwList.push(k); kwRender(); } }
      function kwRemove(i) { kwList.splice(i, 1); kwRender(); }
      function kwKeyDown(e) {
        if (e.key === "Enter" || e.key === ",") { e.preventDefault(); kwAdd(); }
        else if (e.key === "Backspace" && !e.target.value && kwList.length) { kwList.pop(); kwRender(); }
      }
      document.addEventListener("DOMContentLoaded", kwLoad);

      // ─── 关键字命中预览 ───
      function previewMatch() {
        const kwStr = document.getElementById("fld-keywords").value;
        const text = document.getElementById("fld-preview-text").value;
        const out = document.getElementById("preview-out");
        const keywords = kwStr.split(/[,，、\n\r]+/).map(s => s.trim()).filter(Boolean);
        if (keywords.length === 0) { out.innerHTML = '<span style="color:var(--text-dim);">没有关键字</span>'; return; }
        if (!text) { out.innerHTML = '<span style="color:var(--text-dim);">没有测试文本</span>'; return; }
        const hits = keywords.filter(k => text.includes(k));
        // 高亮原文中命中部分
        let html = text;
        // 先做 HTML escape
        html = html.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        // 由长到短替换防短字串包在长字串里漏标
        keywords.slice().sort((a, b) => b.length - a.length).forEach(k => {
          if (!k) return;
          const esc = k.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          const re = new RegExp(esc.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g');
          html = html.replace(re, '<mark style="background:rgba(255,201,64,0.35);color:var(--text-0);padding:0 2px;border-radius:2px;">' + esc + '</mark>');
        });
        const color = hits.length > 0 ? 'var(--green)' : 'var(--text-dim)';
        const summary = hits.length > 0
          ? '<span style="color:var(--green);font-weight:700;">✓ 命中 ' + hits.length + ' 个</span>: ' + hits.map(h => '<code style="background:rgba(255,201,64,0.2);padding:0 4px;border-radius:3px;">' + h + '</code>').join(' ')
          : '<span style="color:var(--text-dim);">没命中任何关键字</span>';
        out.innerHTML = '<div style="margin-bottom:0.5rem;font-size:0.8rem;">' + summary + '</div><div style="color:var(--text-1);">' + html + '</div>';
      }
      previewMatch();
    </script>
  </div>

  <div class="panel">
    <div class="panel-title">进阶参数</div>
    <div class="form-group">
      <label>关键字冷却时间（分钟）</label>
      <input type="number" name="cooldownMinutes" min="0" step="1"
        value="<%= fd.cooldownMinutes != null ? fd.cooldownMinutes : Math.round((cfg.cooldownMs || 600000) / 60000) %>">
      <div class="hint">同群同关键字多久内不重推，防刷屏。默认 10 分钟.</div>
    </div>
    <div class="form-group">
      <label>消息摘要长度（字符数）</label>
      <input type="number" name="summaryMaxLength" min="20" step="1"
        value="<%= fd.summaryMaxLength != null ? fd.summaryMaxLength : (cfg.summaryMaxLength || 120) %>">
      <div class="hint">推送到中转群时，消息内容最多显示多少字符. 默认 120.</div>
    </div>
    <div class="form-group">
      <label>Backfill 间隔（秒）</label>
      <input type="number" name="backfillIntervalSec" min="10" step="1"
        value="<%= fd.backfillIntervalSec != null ? fd.backfillIntervalSec : Math.round((cfg.backfillIntervalMs || 60000) / 1000) %>">
      <div class="hint">sheet_writer 每 N 秒补扫最近消息（防漏）。默认 60 秒.</div>
    </div>
    <div class="form-group">
      <label>Backfill 扫几条</label>
      <input type="number" name="backfillLimit" min="1" step="1"
        value="<%= fd.backfillLimit != null ? fd.backfillLimit : (cfg.backfillLimit || 30) %>">
      <div class="hint">每次补扫看最近几条消息。默认 30.</div>
    </div>
  </div>

  <div style="display: flex; gap: 1rem; justify-content: flex-end;">
    <a href="/depts" class="btn ghost">取消</a>
    <button type="submit" class="btn">保存并重启进程</button>
  </div>
</form>

<%- include('../partials/log-panel', {
  apiBase: `/api/logs/dept/${dept.name}`,
  kinds: [ { id: 'worker', label: 'worker' } ]
}) %>
