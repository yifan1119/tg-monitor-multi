<% const fd = locals.formData || {}; const cfg = locals.config || {}; %>
<div class="page-header">
  <div>
    <div class="page-title">编辑全局进程 · <%= kind %></div>
    <div class="page-subtitle">修改 <code>global/<%= kind %>/config.json</code></div>
  </div>
  <div><a href="/settings" class="btn ghost">返回设置</a></div>
</div>

<% if (locals.flash) { %>
  <div class="panel" style="border-left: 3px solid var(--green); background: rgba(0, 255, 149, 0.06);">
    <div style="color: var(--green); font-weight: 700; font-size: 0.85rem;">✓ <%= flash %></div>
  </div>
<% } %>
<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem; margin-bottom: 0.4rem;">⚠ 保存失败</div>
    <div style="color: var(--text-0); font-size: 0.9rem;"><%= error %></div>
  </div>
<% } %>

<!-- ═══ 整体业务说明 ═══ -->
<div class="panel" style="background: rgba(0, 230, 255, 0.04); border-left: 3px solid var(--accent);">
  <div style="font-weight: 700; color: var(--accent); margin-bottom: 0.5rem;">ℹ 这个进程做什么</div>
  <% if (kind === "title-sheet-writer") { %>
    <div style="font-size: 0.85rem; color: var(--text-1); line-height: 1.9;">
      <strong>跨部门群名变更汇总</strong>。一个"汇总员"TG 号同时加入 N 个部门的中转群
      （例如<code>悦达-业务审查</code>、<code>逸品-业务审查</code>...）。
      当某个中转群内出现<strong>"群名变更提醒"</strong>消息时（由该部门的 listener 推送），
      本进程根据消息来自<strong>哪个中转群</strong>，去下面 <code>routes</code> 里查对应的
      Google Sheet → 把群名变更事件写到该部门的 Sheet 里。
      <br><br>
      <strong style="color: var(--yellow);">用途：</strong>
      每个广告帐号（客户群）改名的履历跨部门集中记录，谁在什么时间把客户群改成了什么状态，一查可见。
    </div>
  <% } else if (kind === "review-report-writer") { %>
    <div style="font-size: 0.85rem; color: var(--text-1); line-height: 1.9;">
      <strong>审查报告闭环跟踪</strong>。一个"观察员"TG 号订阅 N 个部门的<strong>审查报告群</strong>
      （不是中转群！另一批群，例<code>悦达-审查报告</code>）。
      当某群里出现含"审查报告"关键字的消息 → 建立一笔记录。
      之后出现含"闭环处理结果说明"的消息 → 关闭这笔记录（闭环）。
      所有部门的记录<strong>全部汇总到同一张 Sheet</strong>。
      <br><br>
      <strong style="color: var(--yellow);">用途：</strong>
      稽核 — 谁家有多少问题没闭环、平均闭环时间、按部门统计问题量。
    </div>
  <% } %>
</div>

<!-- ═══ 进程状态 + TG 登入 ═══ -->
<div class="panel">
  <div class="panel-title">进程状态 / TG 登入</div>
  <table>
    <tbody>
      <tr>
        <td style="color: var(--text-dim); width: 140px;">PM2 进程</td>
        <td>
          <code>tg-<%= kind %></code>
          <% if (proc) { %>
            · <span class="status-<%= proc.status %>">● <%= proc.status %></span>
            · CPU <%= proc.cpu.toFixed(1) %>% · RAM <%= proc.mem %> MB · 重启 <%= proc.restarts %> 次
          <% } else { %>
            · <span style="color: var(--text-dim);">未启动</span>
          <% } %>
        </td>
      </tr>
      <tr>
        <td style="color: var(--text-dim);">TG Session</td>
        <td>
          <% if (g.sessionOk) { %>
            <span class="dot green"></span>已登入
            <a href="/settings/global/<%= kind %>/login" class="btn ghost" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; margin-left: 0.5rem;">重新登入</a>
          <% } else { %>
            <span class="dot yellow"></span>未登入
            <a href="/settings/global/<%= kind %>/login" class="btn" style="padding: 0.25rem 0.7rem; font-size: 0.7rem; margin-left: 0.5rem;">🔑 去登入</a>
          <% } %>
        </td>
      </tr>
    </tbody>
  </table>
  <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
    <form action="/settings/global/<%= kind %>/restart" method="POST" style="display:inline;">
      <button type="submit" class="btn ghost" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">↻ 重启</button>
    </form>
    <form action="/settings/global/<%= kind %>/start" method="POST" style="display:inline;">
      <button type="submit" class="btn ghost" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">▶ 启动</button>
    </form>
    <form action="/settings/global/<%= kind %>/stop" method="POST" style="display:inline;">
      <button type="submit" class="btn ghost" style="padding: 0.4rem 0.9rem; font-size: 0.75rem;">⏸ 停止</button>
    </form>
  </div>
</div>

<!-- ═══ Config 表单 ═══ -->
<form action="/settings/global/<%= kind %>/edit" method="POST">

<% if (kind === "title-sheet-writer") { %>

  <div class="panel">
    <div class="panel-title">订阅路由 (routes)</div>
    <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.8;">
      <strong>核心配置</strong>。每一条路由告诉系统："来自 <em>某某中转群</em> 的消息 → 写到 <em>哪张 Sheet 的哪个分页</em>"。
      <br>
      有几个部门，就要有几条路由（不然那些部门的群名变更不会被写）。
    </div>
    <datalist id="tg-groups"></datalist>
    <% if (g.sessionOk) { %>
      <div style="margin-bottom: 0.75rem;">
        <button type="button" class="btn ghost" style="padding:0.3rem 0.7rem;font-size:0.72rem;" onclick="loadTgGroups()">🔍 载入该汇总员号加入的群 (给路由做下拉建议)</button>
        <span id="tg-groups-meta" style="font-size:0.72rem;color:var(--text-dim);margin-left:0.5rem;"></span>
      </div>
      <script>
        async function loadTgGroups() {
          const meta = document.getElementById("tg-groups-meta");
          meta.textContent = '拉取中...';
          try {
            const r = await fetch("/api/tg-dialogs/global/<%= kind %>").then(r => r.json());
            if (!r.ok) { meta.innerHTML = '<span style="color:var(--red);">✗ ' + r.error + '</span>'; return; }
            const dl = document.getElementById("tg-groups");
            dl.innerHTML = '';
            r.dialogs.forEach(d => {
              const opt = document.createElement("option");
              opt.value = d.title; opt.label = d.type;
              dl.appendChild(opt);
            });
            // 把 datalist 应用到所有 route_key 输入
            document.querySelectorAll('input[name="route_key"]').forEach(i => i.setAttribute('list', 'tg-groups'));
            meta.innerHTML = '<span style="color:var(--green);">✓ 载入 ' + r.dialogs.length + ' 个群</span>' + (r.cached ? ' <span style="color:var(--text-dim);">(缓存)</span>' : '') + ' — 点「中转群名称」输入框看下拉';
          } catch (e) { meta.innerHTML = '<span style="color:var(--red);">请求失败: ' + e.message + '</span>'; }
        }
      </script>
    <% } else { %>
      <div style="margin-bottom: 0.75rem; color: var(--text-dim); font-size: 0.78rem;">💡 登入 TG 后可用下拉选群 (现在要手打群名)</div>
    <% } %>
    <div id="routes-container">
      <% const routes = cfg.routes || {}; const routeEntries = Object.entries(routes); %>
      <% if (routeEntries.length === 0) { routeEntries.push(["", { instance: "", spreadsheetId: "", sheetName: "" }]); } %>
      <% routeEntries.forEach(([key, val], i) => { %>
        <div class="route-row" style="border: 1px solid var(--panel-border); border-radius: 8px; padding: 1rem; margin-bottom: 0.75rem; background: rgba(7, 10, 21, 0.3);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <strong style="color: var(--accent); font-size: 0.8rem;">路由 #<%= i + 1 %></strong>
            <button type="button" class="btn ghost" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; color: var(--red); border-color: var(--red);"
              onclick="this.closest('.route-row').remove()">✕ 删除此路由</button>
          </div>
          <div class="form-group">
            <label>中转群名称（消息来源）</label>
            <input type="text" name="route_key" list="tg-groups" value="<%= key %>" placeholder="例: 悦达-业务审查">
            <div class="hint">这个"汇总员"号<strong>必须已加入这个群</strong>. 填跟 listener 推送目标（该部门的 outputChatName）一模一样的名字</div>
          </div>
          <div class="form-group">
            <label>部门代号（标识用，方便对照）</label>
            <input type="text" name="route_inst" value="<%= val.instance || '' %>" placeholder="例: yueda">
            <div class="hint">对应 <code>depts/&lt;这个名字&gt;</code>, 写到 Sheet 时不显示, 只是标识方便对照</div>
          </div>
          <div class="form-group">
            <label>目标 Spreadsheet ID</label>
            <input type="text" name="route_sheet" value="<%= val.spreadsheetId || '' %>" placeholder="1Q9pMXg5I1dU...">
            <div class="hint">这条路由匹配到的事件写到<strong>这张 Sheet</strong>. 从 Sheet 网址 <code>/d/&lt;ID&gt;/edit</code> 取. 不同部门通常是不同的 Sheet</div>
          </div>
          <div class="form-group">
            <label>目标工作表分页</label>
            <input type="text" name="route_tab" value="<%= val.sheetName || '' %>" placeholder="例: 广告明细YD">
            <div class="hint">该 Sheet 内的哪个分页. 分页要先在 Sheet 里手动建好</div>
          </div>
        </div>
      <% }); %>
    </div>
    <button type="button" class="btn ghost" onclick="addRoute()">+ 新增一条路由</button>

    <script>
      function addRoute() {
        const c = document.getElementById('routes-container');
        const n = c.children.length + 1;
        const row = document.createElement('div');
        row.className = 'route-row';
        row.style.cssText = 'border: 1px solid var(--panel-border); border-radius: 8px; padding: 1rem; margin-bottom: 0.75rem; background: rgba(7, 10, 21, 0.3);';
        row.innerHTML = `
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <strong style="color: var(--accent); font-size: 0.8rem;">路由 #` + n + `</strong>
            <button type="button" class="btn ghost" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; color: var(--red); border-color: var(--red);" onclick="this.closest('.route-row').remove()">✕ 删除此路由</button>
          </div>
          <div class="form-group"><label>中转群名称（消息来源）</label>
            <input type="text" name="route_key" list="tg-groups" placeholder="例: 悦达-业务审查">
            <div class="hint">"汇总员"号必须已加入这个群</div></div>
          <div class="form-group"><label>部门代号</label>
            <input type="text" name="route_inst" placeholder="例: yueda"></div>
          <div class="form-group"><label>目标 Spreadsheet ID</label>
            <input type="text" name="route_sheet"></div>
          <div class="form-group"><label>目标工作表分页</label>
            <input type="text" name="route_tab" placeholder="例: 广告明细YD"></div>`;
        c.appendChild(row);
      }
    </script>
  </div>

<% } else if (kind === "review-report-writer") { %>

  <div class="panel">
    <div class="panel-title">订阅的审查报告群</div>
    <div class="form-group">
      <label>群名列表</label>
      <input type="hidden" name="input_chats" id="fld-input-chats" value="<%= (cfg.inputChatNames || []).join(', ') %>">
      <div id="ic-tags" style="display:flex;flex-wrap:wrap;gap:0.4rem;padding:0.5rem;min-height:48px;background:rgba(7,10,21,0.4);border:1px solid var(--panel-border);border-radius:6px;"></div>
      <div style="display:flex;gap:0.5rem;margin-top:0.5rem;align-items:center;">
        <% if (g.sessionOk) { %>
          <button type="button" class="btn ghost" style="padding:0.35rem 0.8rem;font-size:0.75rem;" onclick="openIcPicker()">🔍 从该汇总员号加入的群选</button>
          <span id="ic-picker-meta" style="font-size:0.72rem;color:var(--text-dim);"></span>
        <% } else { %>
          <span style="color:var(--text-dim);font-size:0.72rem;">登入后可从 TG 群下拉选</span>
        <% } %>
      </div>
      <div class="hint" style="margin-top:0.5rem;">
        <strong>订阅这些审查报告群的消息</strong>. 用这个"观察员"TG 号必须已加入全部这些群.
      </div>
      <div id="ic-picker" style="display:none;margin-top:0.6rem;background:var(--panel-bg, #0f1420);border:1px solid var(--accent);border-radius:8px;max-height:360px;overflow:hidden;">
        <div style="padding:0.6rem;border-bottom:1px solid var(--panel-border);">
          <input type="text" id="ic-picker-search" placeholder="🔍 搜索群名..." style="width:100%;padding:0.4rem 0.6rem;background:rgba(7,10,21,0.5);border:1px solid var(--panel-border);border-radius:4px;color:var(--text-0);font-size:0.85rem;" oninput="filterIcList()">
        </div>
        <div id="ic-picker-list" style="max-height:260px;overflow-y:auto;padding:0.3rem 0;"></div>
        <div style="padding:0.3rem 0.6rem;border-top:1px solid var(--panel-border);font-size:0.7rem;color:var(--text-dim);display:flex;justify-content:space-between;">
          <span id="ic-picker-count">—</span>
          <button type="button" onclick="document.getElementById('ic-picker').style.display='none'" style="background:none;border:none;color:var(--text-dim);font-size:0.7rem;cursor:pointer;">关闭</button>
        </div>
      </div>
      <script>
        let icList = [];
        let icAllGroups = [];
        function icLoad() {
          icList = document.getElementById("fld-input-chats").value.split(/[,，、\n\r]+/).map(s => s.trim()).filter(Boolean);
          icRender();
        }
        function icRender() {
          const box = document.getElementById("ic-tags");
          if (icList.length === 0) {
            box.innerHTML = '<span style="color:var(--text-dim);font-size:0.8rem;align-self:center;">(没群 — 点上面按钮选)</span>';
          } else {
            box.innerHTML = icList.map((k, i) => {
              const esc = String(k).replace(/"/g, '&quot;').replace(/</g, '&lt;');
              return '<span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.25rem 0.5rem 0.25rem 0.7rem;background:rgba(0,230,255,0.1);border:1px solid rgba(0,230,255,0.3);border-radius:14px;color:var(--accent);font-size:0.8rem;">' +
                '<span>' + esc + '</span>' +
                '<button type="button" onclick="icRemove(' + i + ')" style="background:none;border:none;color:var(--red);font-size:1rem;cursor:pointer;padding:0;line-height:1;">×</button>' +
                '</span>';
            }).join('');
          }
          document.getElementById("fld-input-chats").value = icList.join(", ");
        }
        function icRemove(i) { icList.splice(i, 1); icRender(); }
        function icAdd(name) { if (!icList.includes(name)) { icList.push(name); icRender(); } }
        async function openIcPicker() {
          const picker = document.getElementById("ic-picker");
          const listEl = document.getElementById("ic-picker-list");
          const meta = document.getElementById("ic-picker-meta");
          picker.style.display = "block";
          listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">拉取中...</div>';
          try {
            const r = await fetch("/api/tg-dialogs/global/<%= kind %>").then(r => r.json());
            if (!r.ok) { listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">✗ ' + r.error + '</div>'; return; }
            icAllGroups = r.dialogs;
            renderIcList(icAllGroups);
            meta.innerHTML = '<span style="color:var(--green);">✓ ' + r.dialogs.length + ' 个群' + (r.cached ? ' (缓存)' : '') + '</span>';
          } catch (e) { listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">请求失败: ' + e.message + '</div>'; }
        }
        function renderIcList(list) {
          const listEl = document.getElementById("ic-picker-list");
          const count = document.getElementById("ic-picker-count");
          if (list.length === 0) { listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">没匹配的群</div>'; count.textContent = '0 / ' + icAllGroups.length; return; }
          listEl.innerHTML = list.map(d => {
            const picked = icList.includes(d.title);
            const esc = String(d.title).replace(/"/g, '&quot;').replace(/</g, '&lt;');
            return '<div data-ic-title="' + esc + '" style="padding:0.4rem 0.8rem;cursor:pointer;font-size:0.85rem;color:' + (picked ? 'var(--text-dim)' : 'var(--text-0)') + ';display:flex;justify-content:space-between;align-items:center;" onmouseover="this.style.background=\'rgba(0,230,255,0.08)\'" onmouseout="this.style.background=\'\'">' +
              '<span>' + (picked ? '✓ ' : '') + esc + '</span>' +
              '<span style="color:var(--text-dim);font-size:0.7rem;">' + d.type + '</span>' +
            '</div>';
          }).join('');
          count.textContent = list.length + ' / ' + icAllGroups.length;
        }
        // 简化 onclick: 用 data attr 避免 encode 混乱
        document.addEventListener("click", e => {
          const el = e.target.closest("[data-ic-title]");
          if (el) icAdd(el.getAttribute("data-ic-title"));
        });
        function filterIcList() {
          const q = document.getElementById("ic-picker-search").value.toLowerCase().trim();
          if (!q) return renderIcList(icAllGroups);
          renderIcList(icAllGroups.filter(d => d.title.toLowerCase().includes(q)));
        }
        document.addEventListener("DOMContentLoaded", icLoad);
      </script>
    </div>
  </div>

  <div class="panel">
    <div class="panel-title">目标汇总 Sheet</div>
    <div style="color: var(--text-dim); font-size: 0.8rem; margin-bottom: 1rem;">
      所有部门的审查报告<strong>汇总到同一张</strong> Sheet（不分流到各部门）
    </div>
    <div class="form-group">
      <label>Spreadsheet ID</label>
      <input type="text" id="fld-spreadsheetId" name="spreadsheetId" value="<%= cfg.spreadsheetId || '' %>" placeholder="1lu4J3v9GsDO..." required autocomplete="off">
      <div class="hint">从 Sheet 网址 <code>/d/&lt;ID&gt;/edit</code> 取. Sheet 必须把 Google SA email 加为"编辑者"</div>
    </div>
    <div class="form-group" style="position:relative;">
      <label>工作表分页名称</label>
      <input type="text" id="fld-sheetName" name="sheetName" value="<%= cfg.sheetName || '审查报告001' %>" required autocomplete="off">
      <div class="hint">
        <button type="button" class="btn ghost" style="padding:0.15rem 0.5rem;font-size:0.7rem;" onclick="openTabPicker2()">🔍 从该 Sheet 载入分页列表</button>
        <span id="tab-picker-meta2" style="font-size:0.72rem;color:var(--text-dim);margin-left:0.4rem;"></span>
      </div>
      <div id="tab-picker2" style="display:none;position:absolute;left:0;right:0;top:calc(100% + 30px);background:var(--panel-bg, #0f1420);border:1px solid var(--accent);border-radius:8px;z-index:100;max-height:300px;overflow:hidden;">
        <div id="tab-picker-list2" style="max-height:260px;overflow-y:auto;padding:0.3rem 0;"></div>
      </div>
      <script>
        async function openTabPicker2() {
          const id = document.getElementById("fld-spreadsheetId").value.trim();
          const meta = document.getElementById("tab-picker-meta2");
          const picker = document.getElementById("tab-picker2");
          const listEl = document.getElementById("tab-picker-list2");
          if (!id) { meta.innerHTML = '<span style="color:var(--red);">先填 Spreadsheet ID</span>'; return; }
          picker.style.display = "block";
          listEl.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">载入中...</div>';
          try {
            const r = await fetch("/api/sheet-tabs?spreadsheetId=" + encodeURIComponent(id)).then(r => r.json());
            if (!r.ok) { listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">✗ ' + r.error + '</div>'; return; }
            listEl.innerHTML = r.tabs.map(t => {
              const esc = String(t.title).replace(/"/g, '&quot;').replace(/</g, '&lt;');
              return '<div data-tab-title="' + esc + '" style="padding:0.45rem 0.8rem;cursor:pointer;font-size:0.85rem;" onmouseover="this.style.background=\'rgba(0,230,255,0.08)\'" onmouseout="this.style.background=\'\'">' + esc + '</div>';
            }).join('');
            meta.innerHTML = '<span style="color:var(--green);">✓ ' + r.tabs.length + ' 个分页</span>';
          } catch (e) { listEl.innerHTML = '<div style="padding:1rem;color:var(--red);">请求失败: ' + e.message + '</div>'; }
        }
        document.addEventListener("click", e => {
          const el = e.target.closest("[data-tab-title]");
          if (el) { document.getElementById("fld-sheetName").value = el.getAttribute("data-tab-title"); document.getElementById("tab-picker2").style.display = "none"; }
          const picker = document.getElementById("tab-picker2");
          if (picker && picker.style.display !== "none" && !picker.contains(e.target) && !e.target.closest('button[onclick="openTabPicker2()"]')) picker.style.display = "none";
        });
      </script>
    </div>
    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
      <button type="button" class="btn ghost" style="padding:0.4rem 0.9rem;font-size:0.75rem;" onclick="testSheetWrite()">🧪 测试写入</button>
      <button type="button" class="btn ghost" style="padding:0.4rem 0.9rem;font-size:0.75rem;color:var(--accent);border-color:var(--accent);" onclick="initSheetTemplateG()">⚡ 初始化模板</button>
      <span id="sheet-test-result" style="font-size:0.78rem;color:var(--text-dim);"></span>
    </div>
    <script>
      async function initSheetTemplateG() {
        const out = document.getElementById("sheet-test-result");
        const spreadsheetId = document.getElementById("fld-spreadsheetId").value.trim();
        const sheetName = document.getElementById("fld-sheetName").value.trim();
        if (!spreadsheetId || !sheetName) { out.innerHTML = '<span style="color:var(--red);">先填 ID + 分页</span>'; return; }
        if (!confirm('⚡ 初始化审查报告模板 "' + sheetName + '"?')) return;
        out.innerHTML = '初始化中...';
        try {
          const r = await fetch("/api/sheet-template/init", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ spreadsheetId, sheetName, type: "review" }),
          }).then(r => r.json());
          if (r.ok) {
            out.innerHTML = '<span style="color:var(--green);">✓ ' + (r.created ? '已建分页' : '已重设模板') + ' (' + r.headers.length + ' 列) · ' + r.spreadsheetTitle + '</span>';
          } else { out.innerHTML = '<span style="color:var(--red);">✗ ' + r.error + '</span>'; }
        } catch (e) { out.innerHTML = '<span style="color:var(--red);">请求失败: ' + e.message + '</span>'; }
      }
    </script>
    <script>
      async function testSheetWrite() {
        const out = document.getElementById("sheet-test-result");
        const spreadsheetId = document.getElementById("fld-spreadsheetId").value.trim();
        const sheetName = document.getElementById("fld-sheetName").value.trim();
        if (!spreadsheetId || !sheetName) { out.innerHTML = '<span style="color:var(--red);">请先填 ID + 分页</span>'; return; }
        out.innerHTML = '测试中...';
        try {
          const r = await fetch("/api/test/sheet", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ spreadsheetId, sheetName }) }).then(r => r.json());
          if (r.ok) {
            out.innerHTML = '<span style="color:var(--green);">✓ 写入成功</span> <span style="color:var(--text-dim);">(' + r.sheetTitle + ', 测试行已清理)</span>';
          } else {
            let html = '<span style="color:var(--red);">✗ ' + r.error + '</span>';
            if (r.availableTabs) html += '<br><span style="color:var(--text-dim);">可用分页: ' + r.availableTabs.join(", ") + '</span>';
            out.innerHTML = html;
          }
        } catch (e) { out.innerHTML = '<span style="color:var(--red);">请求失败: ' + e.message + '</span>'; }
      }
    </script>
  </div>

  <div class="panel">
    <div class="panel-title">闭环跟踪关键字</div>
    <div class="form-group">
      <label>触发关键字（建立记录）</label>
      <input type="text" name="keyword" value="<%= cfg.keyword || '审查报告' %>" required>
      <div class="hint">消息包含这个词 → 建立一笔待闭环记录. 预设 <code>审查报告</code></div>
    </div>
    <div class="form-group">
      <label>闭环关键字（关闭记录）</label>
      <input type="text" name="resultKeyword" value="<%= cfg.resultKeyword || '闭环处理结果说明' %>" required>
      <div class="hint">后续消息包含这个词 → 关闭对应记录. 预设 <code>闭环处理结果说明</code></div>
    </div>
    <div class="form-group">
      <label>
        <input type="checkbox" name="strictMode" value="on" <%= cfg.strictMode !== false ? "checked" : "" %>>
        严格模式
      </label>
      <div class="hint">开启时: 只认完全匹配关键字的消息. 关闭时: 含关键字作为子串也算</div>
    </div>
  </div>

<% } %>

  <div class="panel">
    <div class="panel-title">进阶参数（通用）</div>
    <div class="form-group">
      <label>Backfill 间隔（秒）</label>
      <input type="number" name="backfillIntervalSec" min="10" step="1"
        value="<%= Math.round((cfg.backfillIntervalMs || 60000) / 1000) %>">
      <div class="hint">每 N 秒补扫最近消息（防漏）。默认 60 秒</div>
    </div>
    <div class="form-group">
      <label>Backfill 扫几条</label>
      <input type="number" name="backfillLimit" min="1" step="1"
        value="<%= cfg.backfillLimit || 30 %>">
      <div class="hint">每次补扫看最近几条消息. 默认 30</div>
    </div>
  </div>

  <div style="display: flex; gap: 1rem; justify-content: flex-end;">
    <a href="/settings" class="btn ghost">取消</a>
    <button type="submit" class="btn">保存并重启</button>
  </div>
</form>

<%- include('../partials/log-panel', {
  apiBase: `/api/logs/global`,
  kinds: [ { id: kind, label: kind } ]
}) %>
