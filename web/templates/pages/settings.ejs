<div class="page-header">
  <div>
    <div class="page-title">系统设置</div>
    <div class="page-subtitle">TG API · Google SA · 版本. 装完基本不动.</div>
  </div>
</div>

<% if (locals.flash) { %>
  <div class="panel" style="border-left: 3px solid var(--green); background: rgba(0, 255, 149, 0.06);">
    <div style="color: var(--green); font-weight: 700; font-size: 0.85rem;">✓ <%= flash %></div>
  </div>
<% } %>
<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem;">⚠ <%= error %></div>
  </div>
<% } %>

<div class="panel">
  <div class="panel-title">Telegram API</div>
  <table>
    <tbody>
      <tr>
        <td style="color: var(--text-dim); width: 140px;">API ID</td>
        <td><code><%= systemInfo.tgApiId || '(未设置)' %></code></td>
      </tr>
      <tr>
        <td style="color: var(--text-dim);">API Hash</td>
        <td><code><%= systemInfo.tgApiHash ? systemInfo.tgApiHash.slice(0,8) + '...' + systemInfo.tgApiHash.slice(-4) : '(未设置)' %></code></td>
      </tr>
    </tbody>
  </table>
  <div style="font-size: 0.8rem; color: var(--text-dim); margin-top: 0.5rem;">
    从 <a href="https://my.telegram.org" target="_blank" style="color:var(--accent);">my.telegram.org</a> 申请. 每部门共用.
  </div>
</div>

<div class="panel">
  <div class="panel-title">Google Service Account</div>
  <table>
    <tbody>
      <tr>
        <td style="color: var(--text-dim); width: 140px;">状态</td>
        <td>
          <% if (systemInfo.gsaExists) { %>
            <span class="dot green"></span>已设置
            <button type="button" class="btn ghost" style="padding:0.2rem 0.6rem;font-size:0.7rem;margin-left:0.5rem;" onclick="testGsa()">🧪 测试连线</button>
            <span id="gsa-test-result" style="margin-left:0.5rem;font-size:0.75rem;"></span>
          <% } else { %>
            <span class="dot red"></span>未设置
            <a href="/setup" class="btn" style="padding:0.2rem 0.6rem;font-size:0.7rem;margin-left:0.5rem;">去上传</a>
          <% } %>
        </td>
      </tr>
      <% if (systemInfo.gsaExists) { %>
        <tr>
          <td style="color: var(--text-dim);">SA Email</td>
          <td><code><%= systemInfo.gsaEmail %></code></td>
        </tr>
        <tr>
          <td style="color: var(--text-dim);">用途说明</td>
          <td style="font-size: 0.8rem; color: var(--text-1); line-height:1.7;">
            每张 Google Sheet 要把 <strong><%= systemInfo.gsaEmail %></strong> 加为"编辑者", 系统才能写表.
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
  <script>
    async function testGsa() {
      const out = document.getElementById("gsa-test-result");
      out.innerHTML = '测试中...';
      try {
        const r = await fetch("/api/test/gsa", { method: "POST" }).then(r => r.json());
        if (r.ok) out.innerHTML = '<span style="color:var(--green);">✓ 连线 OK (project: ' + r.projectId + ')</span>';
        else out.innerHTML = '<span style="color:var(--red);">✗ ' + r.error + '</span>';
      } catch (e) { out.innerHTML = '<span style="color:var(--red);">请求失败: ' + e.message + '</span>'; }
    }
  </script>
</div>

<div class="panel">
  <div class="panel-title">账号安全 · TG Bot 绑定</div>
  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    <strong style="color:var(--yellow);">强烈建议绑定 TG</strong> — 忘密时 bot 会 DM 发验证码. 没绑过只能 SSH 到服务器手动重置.
  </div>

  <!-- Bot token 配置 -->
  <div style="padding:0.75rem;background:rgba(7,10,21,0.4);border-radius:8px;margin-bottom:1rem;">
    <div style="font-size:0.8rem;margin-bottom:0.5rem;"><strong>1. 配 Bot Token</strong> <span style="color:var(--text-dim);">在 TG 找 @BotFather 发 /newbot 拿 token</span></div>
    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
      <input type="text" id="bot-token-input" placeholder="123456789:ABC-DEF..." style="flex:1;min-width:260px;font-family:'JetBrains Mono',monospace;font-size:0.82rem;">
      <button type="button" class="btn ghost" style="padding:0.35rem 0.8rem;font-size:0.78rem;" onclick="saveBotToken()">保存并启动</button>
      <button type="button" class="btn ghost" style="padding:0.35rem 0.8rem;font-size:0.78rem;color:var(--red);border-color:var(--red);" onclick="clearBotToken()">清除</button>
    </div>
    <div id="bot-status" style="font-size:0.78rem;color:var(--text-dim);margin-top:0.5rem;">查询中...</div>
  </div>

  <!-- 绑定 TG 账号 -->
  <div style="padding:0.75rem;background:rgba(7,10,21,0.4);border-radius:8px;margin-bottom:1rem;">
    <div style="font-size:0.8rem;margin-bottom:0.5rem;"><strong>2. 绑定管理员 TG</strong> <span style="color:var(--text-dim);">bot 跑起来后再做</span></div>
    <div id="bind-area">
      <button type="button" class="btn" style="padding:0.35rem 1rem;font-size:0.8rem;" onclick="getBindCode()">生成绑定码</button>
      <span id="bind-msg" style="font-size:0.78rem;color:var(--text-dim);margin-left:0.5rem;"></span>
    </div>
  </div>

  <script>
    async function refreshBotStatus() {
      try {
        const r = await fetch("/api/auth/bot_status").then(r => r.json());
        const el = document.getElementById("bot-status");
        if (!r.ok) return;
        let html = "";
        html += r.configured ? '<span style="color:var(--green);">● token 已配</span>' : '<span style="color:var(--text-dim);">○ 未配 token</span>';
        html += " · ";
        html += r.running ? '<span style="color:var(--green);">bot 在跑</span>' : '<span style="color:var(--text-dim);">bot 未运行</span>';
        html += " · ";
        html += r.bound ? `<span style="color:var(--green);">已绑定 TG ${r.tg_username ? '@' + r.tg_username : 'user#' + r.tg_user_id}</span> <button type="button" class="btn ghost" style="padding:0.15rem 0.5rem;font-size:0.7rem;margin-left:0.5rem;" onclick="doUnbind()">解绑</button>` : '<span style="color:var(--yellow);">未绑定</span>';
        el.innerHTML = html;
      } catch (e) {}
    }
    async function saveBotToken() {
      const tok = document.getElementById("bot-token-input").value.trim();
      if (!tok) { alert("填 token"); return; }
      const r = await fetch("/api/auth/bot_token", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ token: tok }) }).then(r => r.json());
      if (r.ok) {
        document.getElementById("bot-token-input").value = "";
        alert("已保存, bot 启动中... 稍等几秒再看状态");
        setTimeout(refreshBotStatus, 3000);
      } else {
        alert("保存失败: " + r.error);
      }
    }
    async function clearBotToken() {
      if (!confirm("清除 bot token? 忘记密码功能会失效")) return;
      const r = await fetch("/api/auth/bot_token", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ token: "" }) }).then(r => r.json());
      if (r.ok) refreshBotStatus();
    }
    async function getBindCode() {
      const r = await fetch("/api/auth/bind_start", { method: "POST" }).then(r => r.json());
      const el = document.getElementById("bind-msg");
      if (r.ok) {
        el.innerHTML = `在 bot 里发: <code style="font-size:0.85rem;color:var(--accent);user-select:all;">/bind ${r.code}</code> <span style="color:var(--text-dim);">(${r.ttl_min} 分钟内有效)</span>`;
      } else {
        el.innerHTML = '<span style="color:var(--red);">' + r.error + '</span>';
      }
    }
    async function doUnbind() {
      if (!confirm("解绑 TG? 解绑后忘记密码就没法用了")) return;
      const r = await fetch("/api/auth/unbind", { method: "POST" }).then(r => r.json());
      if (r.ok) refreshBotStatus();
    }
    refreshBotStatus();
  </script>
</div>

<div class="panel">
  <div class="panel-title">外部 API · 中央看板接入</div>
  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    给中央看板 / 监控系统用 Bearer token 拉部门状态 + 告警数据. Schema 跟姊妹项目对齐.
    <strong style="color:var(--yellow);">公网暴露建议先启 HTTPS</strong>
    (<code>bash scripts/enable-https.sh</code>) 避免 token 明文传输.
  </div>
  <table>
    <tbody>
      <tr>
        <td style="color: var(--text-dim); width: 140px; vertical-align: top;">Metrics Token</td>
        <td>
          <code id="metrics-token" style="font-size:0.8rem;user-select:all;word-break:break-all;"><%= systemInfo.metricsToken %></code>
          <button type="button" class="btn ghost" style="margin-left:0.5rem;padding:0.2rem 0.6rem;font-size:0.72rem;"
            onclick="copyMetricsToken(this)">复制</button>
          <button type="button" class="btn ghost" style="padding:0.2rem 0.6rem;font-size:0.72rem;color:var(--yellow);border-color:var(--yellow);"
            onclick="regenMetricsToken()">重置</button>
        </td>
      </tr>
      <tr>
        <td style="color: var(--text-dim); vertical-align: top;">调用示例</td>
        <td>
          <pre style="background:rgba(7,10,21,0.6);padding:0.75rem;border-radius:6px;font-size:0.75rem;margin:0;overflow-x:auto;"><code>curl -H "Authorization: Bearer <span id="curl-token"><%= systemInfo.metricsToken %></span>" \
  <%= systemInfo.publicDomain ? `https://${systemInfo.publicDomain}` : 'http://<VPS_IP>:PORT' %>/api/v1/metrics</code></pre>
        </td>
      </tr>
      <tr>
        <td style="color: var(--text-dim);">最近调用</td>
        <td><span id="metrics-log-meta" style="font-size:0.8rem;color:var(--text-dim);">载入中...</span></td>
      </tr>
    </tbody>
  </table>
  <script>
    // HTTP 环境 navigator.clipboard 被浏览器禁用, fallback 到 execCommand
    function copyMetricsToken(btn) {
      const txt = document.getElementById("metrics-token").textContent;
      const done = () => { btn.textContent = "已复制"; setTimeout(() => btn.textContent = "复制", 1500); };
      // 优先 clipboard API (HTTPS / localhost 生效)
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(txt).then(done).catch(() => fallback(txt, done));
      } else {
        fallback(txt, done);
      }
    }
    function fallback(txt, done) {
      const ta = document.createElement("textarea");
      ta.value = txt;
      ta.style.position = "fixed"; ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); done(); }
      catch { alert("浏览器拒绝复制, 请手动选中 token 复制 (双击即可全选)"); }
      document.body.removeChild(ta);
    }
    async function regenMetricsToken() {
      if (!confirm("重置 token 会让现在所有接入立即失效, 要通知调用方换新 token. 继续?")) return;
      try {
        const r = await fetch("/api/settings/metrics_token/regenerate", { method: "POST" }).then(r => r.json());
        if (r.ok) {
          document.getElementById("metrics-token").textContent = r.token;
          const c = document.getElementById("curl-token");
          if (c) c.textContent = r.token;
          alert("已重置. 记得把新 token 给调用方.");
        } else {
          alert("重置失败: " + r.error);
        }
      } catch (e) { alert("请求失败: " + e.message); }
    }
    fetch("/api/v1/metrics/access_log").then(r => r.json()).then(r => {
      const el = document.getElementById("metrics-log-meta");
      if (!el) return;
      if (!r.ok) { el.textContent = "读取失败"; return; }
      if (!r.last_access) { el.innerHTML = '<span style="color:var(--text-dim);">还没被调用过</span>'; return; }
      const t = new Date(r.last_access).toLocaleString("zh-CN", { hour12: false });
      el.innerHTML = `<strong>${r.count_24h}</strong> 次 / 24h · 最近: <code>${t}</code>`;
    }).catch(() => {});
  </script>
</div>

<div class="panel">
  <div class="panel-title">系统信息</div>
  <table>
    <tbody>
      <tr><td style="color: var(--text-dim); width: 140px;">版本</td><td><code><%= systemInfo.version %></code></td></tr>
      <tr><td style="color: var(--text-dim);">运行模式</td><td><%= systemInfo.mode.toUpperCase() %></td></tr>
      <tr><td style="color: var(--text-dim);">Node.js</td><td><code><%= systemInfo.nodeVersion %></code></td></tr>
      <tr><td style="color: var(--text-dim);">安装目录</td><td><code><%= systemInfo.root %></code></td></tr>
    </tbody>
  </table>
</div>
