<% const HEALTHCHECK_COMMAND = "bash scripts/install-healthcheck.sh"; %>
<div class="page-header">
  <div>
    <div class="page-title">系统设置</div>
    <div class="page-subtitle">全局进程 · 健康检查 · 系统资讯</div>
  </div>
</div>

<% if (locals.flash) { %>
  <div class="panel" style="border-left: 3px solid var(--green); background: rgba(0, 255, 149, 0.06);">
    <div style="color: var(--green); font-weight: 700; font-size: 0.85rem;">✓ <%= flash %></div>
  </div>
<% } %>
<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem;">⚠ <%= error %></div>
  </div>
<% } %>

<!-- ═══ 全局进程 ═══ -->
<div class="panel">
  <div class="panel-title">全局进程 (可选, baseline 架构)</div>

  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    跨部门汇总用. 每个全局进程需要一个独立 TG 号 (订阅所有部门的中转群或审查报告群).
    配置复杂度比部门高, 故 <strong style="color: var(--yellow);">编辑 config 和 TG 登入建议用 CLI</strong>.
  </div>

  <div style="overflow-x: auto;">
    <table>
      <thead>
        <tr><th>类型</th><th>用途</th><th>建立状态</th><th>Session</th><th>PM2 状态</th><th>操作</th></tr>
      </thead>
      <tbody>
        <% globalKinds.forEach(gk => {
          const g = globals.find(x => x.kind === gk.kind);
          const p = procs.find(x => x.name === `tg-${gk.kind}`);
        %>
          <tr>
            <td><code>tg-<%= gk.kind %></code></td>
            <td style="font-size: 0.8rem; color: var(--text-dim);"><%= gk.purpose %></td>
            <% if (!g) { %>
              <td><span class="dot gray"></span>未建立</td>
              <td>—</td>
              <td>—</td>
              <td>
                <form action="/settings/global/new" method="POST" style="display:inline;">
                  <input type="hidden" name="kind" value="<%= gk.kind %>">
                  <button type="submit" class="btn ghost" style="padding: 0.35rem 0.8rem; font-size: 0.75rem;">＋ 建立</button>
                </form>
              </td>
            <% } else { %>
              <td><span class="dot green"></span>已建立</td>
              <td>
                <% if (g.sessionOk) { %>
                  <span class="dot green"></span>OK
                <% } else { %>
                  <span class="dot yellow"></span>需登入
                <% } %>
              </td>
              <% if (p) { %>
                <td class="status-<%= p.status %>">● <%= p.status %></td>
              <% } else { %>
                <td style="color: var(--text-dim);">未启动</td>
              <% } %>
              <td>
                <form action="/settings/global/<%= gk.kind %>/restart" method="POST" style="display:inline;">
                  <button type="submit" class="btn ghost" style="padding: 0.3rem 0.6rem; font-size: 0.7rem;">↻</button>
                </form>
                <form action="/settings/global/<%= gk.kind %>/start" method="POST" style="display:inline;">
                  <button type="submit" class="btn ghost" style="padding: 0.3rem 0.6rem; font-size: 0.7rem;">▶</button>
                </form>
                <form action="/settings/global/<%= gk.kind %>/stop" method="POST" style="display:inline;">
                  <button type="submit" class="btn ghost" style="padding: 0.3rem 0.6rem; font-size: 0.7rem;">⏸</button>
                </form>
              </td>
            <% } %>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% if (globals.length > 0) { %>
    <div style="margin-top: 1rem; padding: 0.85rem 1rem; background: rgba(0, 230, 255, 0.04); border-left: 3px solid var(--accent); border-radius: 0 6px 6px 0; font-size: 0.8rem; color: var(--text-1); line-height: 1.8;">
      <strong style="color: var(--accent);">编辑 config / TG 登入 (在 VPS 上跑)</strong>
      <br>
      <% globals.forEach(g => { %>
        · <code style="color: var(--accent);">vi global/<%= g.kind %>/config.json</code><br>
        · <code style="color: var(--accent);">node scripts/login-global.js <%= g.kind %></code><br>
      <% }); %>
    </div>
  <% } %>
</div>

<!-- ═══ 健康检查 ═══ -->
<div class="panel">
  <div class="panel-title">健康检查 · Auto-Restart</div>

  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    cron 每 5 分钟扫一次所有 <code>tg-*</code> 进程, 非 online 的就 <code>pm2 restart</code>.
    <strong style="color: var(--yellow);">listener 不自动重启</strong>
    (重启会掉 TG session, 坏了通常是 session.txt 失效要人工处理).
  </div>

  <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1rem; background: rgba(7, 10, 21, 0.4); border-radius: 8px;">
    <% if (healthcheck.enabled) { %>
      <div style="flex: 1;">
        <div><span class="dot green"></span><strong style="color: var(--green);">已启用</strong></div>
        <div style="color: var(--text-dim); font-size: 0.75rem; margin-top: 0.3rem;">cron: <code><%= healthcheck.cronLine %></code></div>
      </div>
      <form action="/settings/healthcheck/remove" method="POST">
        <button type="submit" class="btn ghost" style="font-size: 0.8rem;">停用</button>
      </form>
    <% } else { %>
      <div style="flex: 1;">
        <div><span class="dot gray"></span><strong style="color: var(--text-dim);">未启用</strong></div>
        <div style="color: var(--text-dim); font-size: 0.75rem; margin-top: 0.3rem;">进程掉线不会自动重启 (需人工 pm2 restart)</div>
      </div>
      <form action="/settings/healthcheck/install" method="POST">
        <button type="submit" class="btn" style="font-size: 0.8rem;">启用</button>
      </form>
    <% } %>
  </div>

  <% if (healthcheck.logTail && healthcheck.logTail.length > 0) { %>
    <div style="margin-top: 1rem;">
      <div style="font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.4rem;">最近 5 条日志:</div>
      <pre style="background: rgba(7, 10, 21, 0.6); padding: 0.75rem; border-radius: 6px; font-size: 0.75rem; color: var(--text-1); overflow-x: auto; margin: 0;"><%= healthcheck.logTail %></pre>
    </div>
  <% } %>
</div>

<!-- ═══ 系统资讯 ═══ -->
<div class="panel">
  <div class="panel-title">系统资讯</div>
  <table>
    <tbody>
      <tr><td style="color: var(--text-dim);">版本</td><td><code><%= systemInfo.version %></code></td></tr>
      <tr><td style="color: var(--text-dim);">模式</td><td><%= systemInfo.mode.toUpperCase() %></td></tr>
      <tr><td style="color: var(--text-dim);">安装目录</td><td><code><%= systemInfo.root %></code></td></tr>
      <tr><td style="color: var(--text-dim);">Node.js</td><td><code><%= systemInfo.nodeVersion %></code></td></tr>
      <tr><td style="color: var(--text-dim);">Google SA</td><td>
        <% if (systemInfo.gsaExists) { %>
          <span class="dot green"></span><%= systemInfo.gsaEmail %>
        <% } else { %>
          <span class="dot yellow"></span>未设置 (到 /setup 上传)
        <% } %>
      </td></tr>
      <tr><td style="color: var(--text-dim);">PM2</td><td><code><%= systemInfo.pm2Available ? "可用" : "不可用 (需 npm i -g pm2)" %></code></td></tr>
    </tbody>
  </table>
</div>

<!-- ═══ 升级 / 回滚 ═══ -->
<div class="panel">
  <div class="panel-title">升级 · 回滚 · 备份</div>

  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    升级和回滚目前只能在 VPS 命令行执行 (需要 git + npm 权限, Web 不直接做).
  </div>

  <table>
    <tbody>
      <tr>
        <td style="color: var(--text-dim); width: 120px;">升级到最新版</td>
        <td><code style="color: var(--accent);">bash scripts/update.sh</code></td>
      </tr>
      <tr>
        <td style="color: var(--text-dim);">列备份</td>
        <td><code style="color: var(--accent);">bash scripts/list-backups.sh</code></td>
      </tr>
      <tr>
        <td style="color: var(--text-dim);">回滚</td>
        <td><code style="color: var(--accent);">bash scripts/rollback.sh .backups/&lt;ts&gt;/</code></td>
      </tr>
      <tr>
        <td style="color: var(--text-dim);">清旧备份</td>
        <td><code style="color: var(--accent);">bash scripts/clean-backups.sh</code></td>
      </tr>
    </tbody>
  </table>
  <% if (backups.count > 0) { %>
    <div style="margin-top: 1rem; padding: 0.75rem 1rem; background: rgba(0, 230, 255, 0.04); border-left: 3px solid var(--accent); border-radius: 0 6px 6px 0; font-size: 0.85rem;">
      当前有 <strong style="color: var(--accent);"><%= backups.count %></strong> 个备份, 总共 <%= backups.totalSize %>
    </div>
  <% } %>
</div>
