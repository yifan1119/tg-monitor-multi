<div class="page-header">
  <div>
    <div class="page-title">审查报告</div>
    <div class="page-subtitle">跨部门审查报告汇总 · 一个"观察员" TG 号订阅各部门审查群, 写入总表</div>
  </div>
</div>

<% if (locals.flash) { %>
  <div class="panel" style="border-left: 3px solid var(--green); background: rgba(0, 255, 149, 0.06);">
    <div style="color: var(--green); font-weight: 700; font-size: 0.85rem;">✓ <%= flash %></div>
  </div>
<% } %>
<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem;">⚠ <%= error %></div>
  </div>
<% } %>

<% if (!built) { %>

  <!-- 未建立 -->
  <div class="panel" style="text-align: center; padding: 3rem 2rem;">
    <div style="font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4;">📋</div>
    <div style="font-size: 1rem; color: var(--text-1); margin-bottom: 0.5rem;">审查报告功能还没启用</div>
    <div style="font-size: 0.85rem; color: var(--text-dim); margin-bottom: 2rem; line-height: 1.7;">
      启用后会跑一个独立 TG 号 (观察员), 订阅<strong>各部门的审查报告群</strong>,<br>
      看到 "审查报告" 格式的消息就记录到汇总表, 之后出现 "闭环处理结果说明" 就关闭记录.
    </div>
    <form action="/settings/global/new" method="POST" style="display:inline;">
      <input type="hidden" name="kind" value="review-report-writer">
      <button type="submit" class="btn">＋ 启用审查报告</button>
    </form>
  </div>

<% } else { %>

  <!-- 已建立 -->
  <div class="panel">
    <div class="panel-title">状态</div>
    <table>
      <tbody>
        <tr>
          <td style="color: var(--text-dim); width: 140px;">进程</td>
          <td>
            <% if (proc) { %>
              <span class="status-<%= proc.status %>">● <%= STATUS_LABEL[proc.status] || proc.status %></span>
              · CPU <%= proc.cpu.toFixed(1) %>% · 内存 <%= proc.mem %> MB · 已重启 <%= proc.restarts %> 次
            <% } else { %>
              <span style="color: var(--text-dim);">未启动</span>
            <% } %>
          </td>
        </tr>
        <tr>
          <td style="color: var(--text-dim);">TG 账号</td>
          <td>
            <% if (sessionOk) { %>
              <span class="dot green"></span>已登入
              <a href="/review/login" class="btn ghost" style="padding:0.2rem 0.6rem;font-size:0.7rem;margin-left:0.5rem;">重新登入</a>
            <% } else { %>
              <span class="dot yellow"></span>未登入
              <a href="/review/login" class="btn" style="padding:0.25rem 0.7rem;font-size:0.7rem;margin-left:0.5rem;">🔑 去登入</a>
            <% } %>
          </td>
        </tr>
        <tr>
          <td style="color: var(--text-dim);">订阅的群</td>
          <td><%= (config.inputChatNames || []).length %> 个</td>
        </tr>
        <tr>
          <td style="color: var(--text-dim);">总表</td>
          <td>
            <% if (config.spreadsheetId) { %>
              <a href="https://docs.google.com/spreadsheets/d/<%= config.spreadsheetId %>/edit" target="_blank" style="color:var(--accent);">打开 Sheet ↗</a>
              · <%= config.sheetName || '(分页未设)' %>
            <% } else { %>
              <span style="color: var(--yellow);">未配置</span>
            <% } %>
          </td>
        </tr>
      </tbody>
    </table>
    <div style="display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap;">
      <a href="/review/edit" class="btn">编辑配置</a>
      <form action="/review/restart" method="POST" style="display:inline;">
        <button type="submit" class="btn ghost">↻ 重启</button>
      </form>
      <form action="/review/start" method="POST" style="display:inline;">
        <button type="submit" class="btn ghost">▶ 启动</button>
      </form>
      <form action="/review/stop" method="POST" style="display:inline;">
        <button type="submit" class="btn ghost">⏸ 停止</button>
      </form>
      <div style="flex:1;"></div>
      <form action="/review/delete" method="POST" style="display:inline;"
        onsubmit="return confirm('⚠ 删除审查报告功能? PM2 进程移除, 目录搬到 .trash (session/config 保留).');">
        <button type="submit" class="btn ghost" style="color:var(--red);border-color:var(--red);">🗑 删除</button>
      </form>
    </div>
  </div>

  <% if (proc) { %>
    <%- include('../partials/log-panel', {
      apiBase: `/api/logs/global`,
      kinds: [ { id: 'review-report-writer', label: 'review-report-writer' } ]
    }) %>
  <% } %>

<% } %>
