<div class="page-header">
  <div>
    <div class="page-title"><%= title %></div>
    <div class="page-subtitle"><%= subtitle %></div>
  </div>
</div>

<div class="panel">
  <div style="text-align: center; padding: 3rem 1rem; color: var(--text-dim);">
    <div style="font-family: 'Orbitron', sans-serif; font-size: 1.2rem; color: var(--accent); margin-bottom: 1rem; letter-spacing: 0.2em;">
      🚧 施工中 · <%= stage %>
    </div>
    <div style="max-width: 500px; margin: 0 auto; line-height: 1.8;">
      <%= description %>
    </div>
    <div style="margin-top: 2rem;">
      <a href="/dashboard" class="btn ghost">返回總覽</a>
    </div>
  </div>
</div>
