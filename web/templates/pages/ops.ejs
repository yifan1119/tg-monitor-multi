<div class="page-header">
  <div>
    <div class="page-title">运维</div>
    <div class="page-subtitle">健康检查 · 升级 · 备份 · 日志</div>
  </div>
</div>

<% if (locals.flash) { %>
  <div class="panel" style="border-left: 3px solid var(--green); background: rgba(0, 255, 149, 0.06);">
    <div style="color: var(--green); font-weight: 700; font-size: 0.85rem;">✓ <%= flash %></div>
  </div>
<% } %>
<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem;">⚠ <%= error %></div>
  </div>
<% } %>

<!-- 健康检查 -->
<div class="panel">
  <div class="panel-title">健康检查 · 自动重启</div>
  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    每 5 分钟扫描所有 <code>tg-*</code> 服务, 非运行中的自动重启.
    <strong style="color: var(--yellow);">部门监控不自动重启</strong> (重启会掉 TG session, 坏了通常是 session 失效要人工处理).
  </div>
  <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1rem; background: rgba(7, 10, 21, 0.4); border-radius: 8px;">
    <% if (healthcheck.enabled) { %>
      <div style="flex: 1;">
        <div><span class="dot green"></span><strong style="color: var(--green);">已启用</strong></div>
        <div style="color: var(--text-dim); font-size: 0.75rem; margin-top: 0.3rem;"><%= healthcheck.cronLine %></div>
      </div>
      <form action="/ops/healthcheck/remove" method="POST">
        <button type="submit" class="btn ghost">停用</button>
      </form>
    <% } else { %>
      <div style="flex: 1;">
        <div><span class="dot gray"></span><strong style="color: var(--text-dim);">未启用</strong></div>
        <div style="color: var(--text-dim); font-size: 0.75rem; margin-top: 0.3rem;">服务掉线不会自动重启</div>
      </div>
      <form action="/ops/healthcheck/install" method="POST">
        <button type="submit" class="btn">启用</button>
      </form>
    <% } %>
  </div>
  <% if (healthcheck.logTail && healthcheck.logTail.length > 0) { %>
    <div style="margin-top: 1rem;">
      <div style="font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.4rem;">最近 5 条日志:</div>
      <pre style="background: rgba(7, 10, 21, 0.6); padding: 0.75rem; border-radius: 6px; font-size: 0.75rem; color: var(--text-1); overflow-x: auto; margin: 0;"><%= healthcheck.logTail %></pre>
    </div>
  <% } %>
</div>

<!-- 升级 -->
<div class="panel">
  <div class="panel-title">升级</div>
  <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
    点「检查更新」会比对远端有没有新版本. <strong style="color:var(--accent);">软升级</strong> 只拉代码 + 重启 tg-* (网页后台不重启);
    <strong style="color:var(--yellow);">需要重建镜像的升级</strong> (Dockerfile 改了) 会提示 SSH 跑命令.
  </div>
  <button type="button" class="btn" onclick="checkUpdates()">🔍 检查更新</button>
  <span id="update-check-loading" style="display:none; margin-left: 1rem; color: var(--text-dim);">检查中...</span>
  <div id="update-check-result" style="display: none; margin-top: 1rem;"></div>
  <script>
    async function checkUpdates() {
      const btn = event.target; const loading = document.getElementById("update-check-loading"); const out = document.getElementById("update-check-result");
      btn.disabled = true; loading.style.display = "inline"; out.style.display = "none";
      try {
        const r = await fetch("/api/updates/check").then(r => r.json());
        loading.style.display = "none"; btn.disabled = false; out.style.display = "block";
        if (!r.ok) { out.innerHTML = `<div style="padding:0.8rem;background:rgba(255,59,92,0.08);border-left:3px solid var(--red);border-radius:0 6px 6px 0;">检查失败: ${r.error}</div>`; return; }
        if (r.behind === 0) { out.innerHTML = `<div style="padding:0.8rem;background:rgba(0,255,149,0.06);border-left:3px solid var(--green);border-radius:0 6px 6px 0;">✓ 已是最新 (<code>${r.currentCommit}</code> · ${r.currentMsg})</div>`; return; }
        const commits = r.commits.map(c => `<li style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;">${c}</li>`).join("");
        let html = `<div style="padding:1rem;background:rgba(0,230,255,0.05);border-left:3px solid var(--accent);border-radius:0 6px 6px 0;">
          <div style="color:var(--accent);font-weight:700;margin-bottom:0.5rem;">⬆ 落后 ${r.behind} 个 commit</div>
          <div style="font-size:0.8rem;color:var(--text-dim);">当前: <code>${r.currentCommit}</code> · ${r.currentMsg}</div>
          <ul style="margin:0.5rem 0 0 1.25rem;color:var(--text-1);">${commits}</ul></div>`;
        if (r.needsImage) {
          const affected = r.changedFiles.filter(f => /^(Dockerfile|docker-compose\.yml|.*package(-lock)?\.json)$/.test(f)).join(", ");
          const rootPath = r.rootPath || "/opt/tg-monitor-multi";
          html += `<div style="margin-top:1rem;padding:1rem;background:rgba(255,201,64,0.08);border-left:3px solid var(--yellow);border-radius:0 6px 6px 0;">
            <div style="color:var(--yellow);font-weight:700;margin-bottom:0.5rem;">⚠ 需要重建镜像</div>
            <div style="font-size:0.85rem;line-height:1.8;">此次升级改了 <code>${affected}</code> (依赖或基础镜像变动), 网页搞不定. 请 SSH 到宿主机跑:<br>
              <code style="color:var(--accent);user-select:all;display:inline-block;margin-top:0.3rem;padding:0.3rem 0.6rem;background:rgba(7,10,21,0.6);border-radius:4px;">cd ${rootPath} && bash scripts/update.sh</code></div></div>`;
        } else {
          html += `<form action="/ops/update" method="POST" style="margin-top:1rem;" onsubmit="return confirm('执行软升级? 自动备份 depts/global/data/secrets.')">
            <button type="submit" class="btn" style="background:linear-gradient(90deg,var(--green),var(--accent));">⬆ 执行软升级</button></form>`;
        }
        out.innerHTML = html;
      } catch (e) { loading.style.display = "none"; btn.disabled = false; out.innerHTML = `<div style="color:var(--red);">${e.message}</div>`; }
    }
  </script>
</div>

<!-- 备份 / 回滚 -->
<div class="panel">
  <div class="panel-title">备份 · 回滚</div>
  <% if (!backupList || backupList.length === 0) { %>
    <div style="color: var(--text-dim); font-size: 0.85rem;">还没有任何备份. 第一次升级会自动建备份.</div>
  <% } else { %>
    <div style="color: var(--text-1); font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.7;">
      每次软升级 / 回滚前会自动备份 <code>depts/ global/ data/ secrets/</code>.
    </div>
    <div style="overflow-x: auto;">
      <table>
        <thead><tr><th>时间戳</th><th>包含</th><th>大小</th><th>建立时间</th><th>操作</th></tr></thead>
        <tbody>
          <% backupList.forEach(b => { %>
            <tr>
              <td><code style="font-size:0.75rem;"><%= b.ts %></code><% if (b.isSafety) { %> <span style="color:var(--yellow);font-size:0.7rem;">safety</span><% } %></td>
              <td style="font-size:0.75rem;color:var(--text-dim);"><%= (b.includes||[]).join(" · ") %></td>
              <td style="font-size:0.75rem;"><%= b.sizeStr %></td>
              <td style="font-size:0.75rem;color:var(--text-dim);"><%= new Date(b.mtime).toLocaleString("zh-CN", { hour12: false, timeZone: "Asia/Shanghai" }) %></td>
              <td>
                <form action="/ops/rollback/<%= b.ts %>" method="POST" style="display:inline;"
                  onsubmit="return confirm('⚠ 回滚到 <%= b.ts %>? 当前状态会先预备份.');">
                  <button type="submit" class="btn ghost" style="padding:0.3rem 0.7rem;font-size:0.75rem;color:var(--yellow);border-color:var(--yellow);">↶ 回滚</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
