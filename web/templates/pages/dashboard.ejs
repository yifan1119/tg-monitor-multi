<div class="page-header">
  <div>
    <div class="page-title">总览 · Dashboard</div>
    <div class="page-subtitle">
      <% if (summary.deptCount === 0) { %>
        尚未新增任何部门
      <% } else { %>
        全系统即时状态 · 最后更新 <%= new Date().toLocaleString("zh-CN", { hour12: false, timeZone: "Asia/Shanghai" }) %>
      <% } %>
    </div>
  </div>
  <% if (summary.deptCount > 0) { %>
    <div><a href="/depts/new" class="btn">＋ 新增部门</a></div>
  <% } %>
</div>

<% if (summary.deptCount === 0) { %>

  <!-- ═══ 空状态：引导新增第一个部门 ═══ -->
  <div class="panel" style="text-align: center; padding: 4rem 2rem;">
    <div style="font-family: 'Orbitron', sans-serif; font-size: 2.2rem; background: linear-gradient(90deg, var(--accent), var(--accent-2), var(--accent-3)); background-size: 200% 200%; -webkit-background-clip: text; background-clip: text; color: transparent; animation: shimmer 5s linear infinite; letter-spacing: 0.2em; margin-bottom: 1rem;">
      READY
    </div>
    <div style="font-size: 1.05rem; color: var(--text-1); margin-bottom: 0.5rem;">
      空模板已就绪，现在开始加入第一个部门
    </div>
    <div style="font-size: 0.85rem; color: var(--text-dim); margin-bottom: 2.5rem; line-height: 1.8;">
      每个部门会自动建立 listener / system-events / sheet-writer 三个 PM2 进程<br>
      同一台 VPS 可以承载多个部门，互相隔离
    </div>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/setup" class="btn">🚀 走设置精灵</a>
      <a href="/depts/new" class="btn ghost">＋ 直接新增部门</a>
    </div>

    <div style="margin-top: 3rem; padding: 1.5rem; background: rgba(7, 10, 21, 0.5); border: 1px dashed var(--panel-border); border-radius: 8px; text-align: left; max-width: 600px; margin-left: auto; margin-right: auto;">
      <div style="font-family: 'Orbitron', sans-serif; font-size: 0.8rem; color: var(--accent); letter-spacing: 0.15em; margin-bottom: 0.75rem;">▸ 快速上手</div>
      <ol style="font-size: 0.85rem; color: var(--text-1); line-height: 2; padding-left: 1.25rem; margin: 0;">
        <li>走 <strong style="color: var(--accent);">设置精灵</strong>: 填 TG API / Google SA / 第一个部门</li>
        <li>到 <strong>部门管理</strong>, 点「编辑」→「🔑 去登入 TG」完成登入 (可复用其他部门的 session)</li>
        <li>在编辑页点「▶ 启动」起 PM2 进程 (listener + system-events + sheet-writer)</li>
        <li>回 Dashboard 看实时状态 · 到「系统设置」开健康检查 cron</li>
      </ol>
    </div>
  </div>

<% } else { %>

  <!-- ═══ 健康摘要卡 (顶部一排灯) ═══ -->
  <% const hs = locals.healthSummary || {}; %>
  <div class="panel" style="padding: 1rem 1.25rem;">
    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center; justify-content: space-between;">
      <%
        const deptsOk = hs.depts && hs.depts.total > 0 && hs.depts.online === hs.depts.totalProcs && hs.depts.sessionBroken === 0;
        const deptsPartial = hs.depts && (hs.depts.online < hs.depts.totalProcs || hs.depts.sessionBroken > 0);
      %>
      <div style="display: flex; align-items: center; gap: 0.6rem;">
        <span class="dot <%= deptsOk ? 'green' : (deptsPartial ? 'yellow' : 'gray') %>" style="width: 12px; height: 12px;"></span>
        <div>
          <div style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em;">部门进程</div>
          <div style="font-size: 0.9rem;"><strong><%= hs.depts.online %></strong> / <%= hs.depts.totalProcs %> online
            <% if (hs.depts.sessionBroken > 0) { %> · <span style="color:var(--yellow);"><%= hs.depts.sessionBroken %> 需登入</span><% } %>
          </div>
        </div>
      </div>

      <%
        const globalOk = hs.globals.built === hs.globals.total && hs.globals.online === hs.globals.total;
        const globalPartial = hs.globals.built > 0 && hs.globals.online < hs.globals.built;
      %>
      <div style="display: flex; align-items: center; gap: 0.6rem;">
        <span class="dot <%= globalOk ? 'green' : (globalPartial ? 'yellow' : (hs.globals.built === 0 ? 'gray' : 'red')) %>" style="width: 12px; height: 12px;"></span>
        <div>
          <div style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em;">全局进程</div>
          <div style="font-size: 0.9rem;"><strong><%= hs.globals.online %></strong> / <%= hs.globals.total %> online
            <% if (hs.globals.built < hs.globals.total) { %> · <span style="color:var(--text-dim);"><%= hs.globals.total - hs.globals.built %> 未建</span><% } %>
          </div>
        </div>
      </div>

      <div style="display: flex; align-items: center; gap: 0.6rem;">
        <span class="dot <%= hs.healthcheck ? 'green' : 'gray' %>" style="width: 12px; height: 12px;"></span>
        <div>
          <div style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em;">Healthcheck</div>
          <div style="font-size: 0.9rem;"><% if (hs.healthcheck) { %>已启用<% } else { %><a href="/settings" style="color:var(--yellow);">去启用</a><% } %></div>
        </div>
      </div>

      <%
        const backupOk = hs.backup.count > 0 && hs.backup.lastAgo !== null && hs.backup.lastAgo < 7;
        const backupStale = hs.backup.lastAgo !== null && hs.backup.lastAgo >= 7;
      %>
      <div style="display: flex; align-items: center; gap: 0.6rem;">
        <span class="dot <%= backupOk ? 'green' : (backupStale ? 'yellow' : 'gray') %>" style="width: 12px; height: 12px;"></span>
        <div>
          <div style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em;">备份</div>
          <div style="font-size: 0.9rem;">
            <% if (hs.backup.count === 0) { %>无备份
            <% } else { %><strong><%= hs.backup.count %></strong> 个 · 最近 <%= hs.backup.lastAgo === 0 ? '今日' : hs.backup.lastAgo + ' 天前' %><% } %>
          </div>
        </div>
      </div>

      <div style="display: flex; align-items: center; gap: 0.6rem;">
        <span class="dot <%= hs.gsa ? 'green' : 'red' %>" style="width: 12px; height: 12px;"></span>
        <div>
          <div style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em;">Google SA</div>
          <div style="font-size: 0.9rem;"><% if (hs.gsa) { %>已设置<% } else { %><a href="/setup" style="color:var(--red);">未设置</a><% } %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ KPI + 部门卡 + 告警 + PM2 表 ═══ -->
  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">部门数</div>
      <div class="kpi-value"><%= summary.deptCount %><span class="kpi-unit">个</span></div>
    </div>
    <div class="kpi green">
      <div class="kpi-label">线上进程</div>
      <div class="kpi-value"><%= summary.procOnline %><span class="kpi-unit">/ <%= summary.procTotal %></span></div>
    </div>
    <div class="kpi <%= summary.procOffline > 0 ? 'red' : '' %>">
      <div class="kpi-label">离线进程</div>
      <div class="kpi-value"><%= summary.procOffline %><span class="kpi-unit">个</span></div>
    </div>
    <div class="kpi <%= summary.sessionBroken > 0 ? 'yellow' : 'green' %>">
      <div class="kpi-label">Session 异常</div>
      <div class="kpi-value"><%= summary.sessionBroken %><span class="kpi-unit">个</span></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">24h 命中关键字</div>
      <div class="kpi-value"><%= summary.totalHit24h %><span class="kpi-unit">次</span></div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-title">部门状态</div>
    <div class="dept-grid">
      <% depts.forEach(d => {
        const deptProcs = procs.filter(p => p.dept === d.name);
        const allOn = deptProcs.length > 0 && deptProcs.every(p => p.status === 'online');
        const someOff = deptProcs.some(p => p.status !== 'online');
        const dotClass = !d.sessionOk ? 'yellow' : allOn ? 'green' : someOff ? 'red' : 'gray';
      %>
        <a href="/depts/<%= d.name %>" class="dept-card">
          <div class="name"><span class="dot <%= dotClass %>"></span><%= d.name %></div>
          <div class="display"><%= d.display %> / <%= d.outputChat %></div>
          <div class="meta">
            <span>24h 命中: <strong style="color:var(--accent);"><%= d.hit24h %></strong></span>
            <span><%= d.lastMsg %></span>
          </div>
        </a>
      <% }); %>
    </div>
  </div>

  <% if (alerts.length > 0) { %>
    <div class="panel">
      <div class="panel-title">最近告警</div>
      <ul class="alert-list">
        <% alerts.forEach(a => { %>
          <li class="<%= a.level %>">
            <span class="ts"><%= a.ts %></span>
            <span class="dept"><%= a.dept %></span>
            <span><%= a.msg %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <% if (procs.length > 0) { %>
    <div class="panel">
      <div class="panel-title">PM2 进程状态 (<%= procs.length %>)</div>
      <div style="overflow-x: auto;">
        <table>
          <thead>
            <tr>
              <th>进程</th>
              <th>部门</th>
              <th>类型</th>
              <th>状态</th>
              <th>CPU</th>
              <th>内存</th>
              <th>重启</th>
              <th>执行时间</th>
            </tr>
          </thead>
          <tbody>
            <% procs.forEach(p => { %>
              <tr>
                <td><strong><%= p.name %></strong></td>
                <td><%= p.dept %></td>
                <td><%= p.kind %></td>
                <td class="status-<%= p.status %>">● <%= p.status %></td>
                <td><%= p.cpu.toFixed(1) %>%</td>
                <td><%= p.mem %> MB</td>
                <td><%= p.restarts %></td>
                <td><%= p.uptime %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

<% } %>
