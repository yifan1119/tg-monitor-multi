<% /* login page — 独立布局，不用 topbar */ %>
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登入 · tg-monitor-multi</title>
  <link rel="stylesheet" href="/css/neon.css">
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <div class="logo">TG·MONITOR</div>
      <div class="subtitle">MULTI · v<%= version %> · 加密连线</div>

      <form action="/login" method="POST">
        <% if (locals.next) { %>
          <input type="hidden" name="next" value="<%= next %>">
        <% } %>
        <div class="form-group">
          <label>账号</label>
          <input type="text" name="username" required autofocus autocomplete="username" placeholder="admin">
        </div>
        <div class="form-group">
          <label>密码</label>
          <input type="password" name="password" required autocomplete="current-password" placeholder="••••••">
        </div>

        <% if (locals.error) { %>
          <div style="color: var(--red); font-size: 0.85rem; margin-bottom: 1rem; text-align: center;">
            <%= error %>
          </div>
        <% } %>

        <button type="submit" class="btn" style="width: 100%;">登入</button>
      </form>

      <div style="text-align: center; margin-top: 1.25rem; font-size: 0.78rem;">
        <a href="/forgot-password" style="color: var(--text-dim);">忘记密码?</a>
      </div>

      <div style="text-align: center; margin-top: 1.25rem; font-size: 0.75rem; color: var(--text-dim);">
        首次设置？<a href="/setup" style="color: var(--accent);">进入设置向导</a>
      </div>
    </div>
  </div>
</body>
</html>
