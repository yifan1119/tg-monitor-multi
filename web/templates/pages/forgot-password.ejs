<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>忘记密码 · tg-monitor-multi</title>
  <link rel="stylesheet" href="/css/neon.css">
</head>
<body>
  <div class="login-wrap">
    <div class="login-card" style="max-width: 420px;">
      <div class="logo">忘记密码</div>
      <div class="subtitle">通过已绑定的 TG Bot 收验证码重置</div>

      <!-- 步骤 1: 输入用户名, 后端经 bot DM 发码 -->
      <div id="step-request">
        <div class="form-group">
          <label>用户名</label>
          <input type="text" id="fp-username" value="<%= locals.username || '' %>" autofocus autocomplete="username" placeholder="admin">
        </div>
        <div style="font-size: 0.78rem; color: var(--text-dim); margin-bottom: 1rem; line-height: 1.6;">
          若该账号已绑定 TG Bot, 我们会 DM 发 6 位验证码到你的 TG.<br>
          没绑过? 只能 SSH 到服务器手动重置.
        </div>
        <button type="button" class="btn" style="width: 100%;" onclick="sendCode()">发送验证码</button>
        <div id="fp-msg" style="font-size: 0.8rem; margin-top: 1rem; text-align: center; min-height: 1.2em;"></div>
      </div>

      <!-- 步骤 2: 填验证码 + 新密码 -->
      <div id="step-reset" style="display: none;">
        <div style="background:rgba(0,230,255,0.06);border-left:3px solid var(--accent);padding:0.75rem;border-radius:0 6px 6px 0;font-size:0.8rem;margin-bottom:1rem;line-height:1.6;">
          ✓ 已尝试 DM 发码到绑定的 TG (若账号存在且已绑定).<br>
          收到后请在下面填入.
        </div>
        <div class="form-group">
          <label>6 位验证码</label>
          <input type="text" id="fp-code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" style="letter-spacing:0.3em;text-align:center;">
        </div>
        <div class="form-group">
          <label>新密码 (至少 8 位)</label>
          <input type="password" id="fp-newpwd" minlength="8" placeholder="••••••••">
        </div>
        <div class="form-group">
          <label>再次确认</label>
          <input type="password" id="fp-newpwd2" minlength="8" placeholder="••••••••">
        </div>
        <button type="button" class="btn" style="width: 100%;" onclick="doReset()">重置密码</button>
        <div id="fp-msg2" style="font-size: 0.8rem; margin-top: 1rem; text-align: center; min-height: 1.2em;"></div>
      </div>

      <div style="text-align: center; margin-top: 1.5rem; font-size: 0.75rem;">
        <a href="/login" style="color: var(--text-dim);">← 回登入</a>
      </div>
    </div>
  </div>

  <script>
    const msg = document.getElementById("fp-msg");
    const msg2 = document.getElementById("fp-msg2");
    const stepReq = document.getElementById("step-request");
    const stepReset = document.getElementById("step-reset");

    let currentUsername = "";

    async function sendCode() {
      const u = document.getElementById("fp-username").value.trim();
      if (!u) { msg.innerHTML = '<span style="color:var(--red);">请输入用户名</span>'; return; }
      msg.textContent = "发送中...";
      try {
        const r = await fetch("/api/auth/forgot_password", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ username: u }),
        }).then(r => r.json());
        if (r.ok) {
          currentUsername = u;
          stepReq.style.display = "none";
          stepReset.style.display = "block";
          document.getElementById("fp-code").focus();
        } else {
          msg.innerHTML = '<span style="color:var(--red);">' + (r.error || "发送失败") + '</span>';
        }
      } catch (e) { msg.innerHTML = '<span style="color:var(--red);">' + e.message + '</span>'; }
    }

    async function doReset() {
      const code = document.getElementById("fp-code").value.trim();
      const p1 = document.getElementById("fp-newpwd").value;
      const p2 = document.getElementById("fp-newpwd2").value;
      if (!code || !p1) { msg2.innerHTML = '<span style="color:var(--red);">参数不完整</span>'; return; }
      if (p1 !== p2) { msg2.innerHTML = '<span style="color:var(--red);">两次密码不一致</span>'; return; }
      if (p1.length < 8) { msg2.innerHTML = '<span style="color:var(--red);">至少 8 位</span>'; return; }
      msg2.textContent = "重置中...";
      try {
        const r = await fetch("/api/auth/reset_password", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ username: currentUsername, code, new_password: p1 }),
        }).then(r => r.json());
        if (r.ok) {
          msg2.innerHTML = '<span style="color:var(--green);">✓ 重置成功, 2 秒后跳登入</span>';
          setTimeout(() => location.href = "/login", 2000);
        } else {
          msg2.innerHTML = '<span style="color:var(--red);">' + (r.error || "重置失败") + '</span>';
        }
      } catch (e) { msg2.innerHTML = '<span style="color:var(--red);">' + e.message + '</span>'; }
    }
  </script>
</body>
</html>
