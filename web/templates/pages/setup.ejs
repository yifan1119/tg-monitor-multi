<% /* setup wizard — 首次設置 */ %>
<% const fd = locals.formData || {}; %>
<div class="page-header">
  <div>
    <div class="page-title">首次設置精靈</div>
    <div class="page-subtitle">填完 4 節設置即可開始第一個部門</div>
  </div>
</div>

<% if (locals.error) { %>
  <div class="panel" style="border-left: 3px solid var(--red); background: rgba(255, 59, 92, 0.06);">
    <div style="color: var(--red); font-weight: 700; font-size: 0.85rem; margin-bottom: 0.4rem;">⚠ 設置失敗</div>
    <div style="color: var(--text-0); font-size: 0.9rem;"><%= error %></div>
    <div style="color: var(--text-dim); font-size: 0.8rem; margin-top: 0.5rem;">請修正後重新提交。原本填的值已保留。</div>
  </div>
<% } %>

<div class="wizard-steps">
  <div class="wizard-step active">1 · 管理員</div>
  <div class="wizard-step">2 · TG API</div>
  <div class="wizard-step">3 · Google SA</div>
  <div class="wizard-step">4 · 第一個部門</div>
</div>

<form action="/setup" method="POST">
  <div class="panel">
    <div class="panel-title">1. Web 後台管理員帳號</div>
    <div class="form-group">
      <label>用戶名</label>
      <input type="text" name="admin_username" placeholder="admin" value="<%= fd.admin_username || '' %>" required>
      <div class="hint">日後登入 Web 後台用</div>
    </div>
    <div class="form-group">
      <label>密碼</label>
      <input type="password" name="admin_password" required>
      <div class="hint">至少 8 字元，建議混用大小寫+數字</div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-title">2. Telegram API 認證</div>
    <div class="form-group">
      <label>TG_API_ID</label>
      <input type="text" name="tg_api_id" placeholder="例: 31462192" value="<%= fd.tg_api_id || '' %>" required>
      <div class="hint">從 <a href="https://my.telegram.org/apps" target="_blank" style="color:var(--accent);">my.telegram.org/apps</a> 取得</div>
    </div>
    <div class="form-group">
      <label>TG_API_HASH</label>
      <input type="text" name="tg_api_hash" placeholder="32 位十六進制" value="<%= fd.tg_api_hash || '' %>" required>
      <div class="hint">同一台 VPS 上的多個部門可共用這組</div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-title">3. Google Service Account（選填 · MVP 暫不處理上傳）</div>
    <div class="form-group">
      <label>上傳 google-service-account.json</label>
      <input type="file" name="google_sa" accept="application/json" disabled>
      <div class="hint">留到下個批次實作。現在請先手動把檔案放到 <code style="color: var(--accent);">shared/google-service-account.json</code></div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-title">4. 第一個部門</div>
    <div class="form-group">
      <label>部門代號 (dept_name)</label>
      <input type="text" name="dept_name" placeholder="例: yueda" pattern="[a-z][a-z0-9-]{1,31}" value="<%= fd.dept_name || '' %>" required
        title="小寫字母開頭, 2-32 字符, 只含 a-z / 0-9 / -">
      <div class="hint"><strong style="color: var(--yellow);">只能用小寫英文+數字+連字號</strong>（不能填中文！），2-32 字符。會作為目錄名和 PM2 進程名。例：<code style="color: var(--accent);">yueda</code>、<code style="color: var(--accent);">dept-01</code></div>
    </div>
    <div class="form-group">
      <label>部門名稱（顯示用，可中文）</label>
      <input type="text" name="dept_display" placeholder="例: 悦达" value="<%= fd.dept_display || '' %>" required>
      <div class="hint">Dashboard 上顯示的名稱，可用中文</div>
    </div>
    <div class="form-group">
      <label>中轉群名稱 (outputChatName)</label>
      <input type="text" name="output_chat" placeholder="例: 悦达-业务审查" value="<%= fd.output_chat || '' %>" required>
      <div class="hint">TG 帳號要先加入這個群</div>
    </div>
    <div class="form-group">
      <label>Google Sheet ID</label>
      <input type="text" name="spreadsheet_id" placeholder="從 Sheet URL 取: /d/<這段>/edit" value="<%= fd.spreadsheet_id || '' %>" required>
      <div class="hint">Sheet 要把 SA email 加為「編輯者」</div>
    </div>
    <div class="form-group">
      <label>工作表分頁名稱</label>
      <input type="text" name="sheet_tab" placeholder="例: 关键词提醒yd" value="<%= fd.sheet_tab || '' %>" required>
    </div>
  </div>

  <div style="display: flex; gap: 1rem; justify-content: flex-end;">
    <button type="submit" class="btn">完成設置 · 建立第一個部門</button>
  </div>
</form>
